{
  "name": "Leveling App",
  "image": "ruby:3.2.2-slim",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "remoteUser": "root",
  "forwardPorts": [3000, 5432],
  "postCreateCommand": "apt-get update && apt-get install -y build-essential postgresql-client libpq-dev && bundle install",
  "customizations": {
    "vscode": {
      "extensions": [
        "rebornix.Ruby",
        "shopify.ruby-lsp",
        "GitHub.copilot"
      ],
      "settings": {
        "[ruby]": {
          "editor.defaultFormatter": "shopify.ruby-lsp",
          "editor.formatOnSave": true
        }
      }
    }
  }
}
