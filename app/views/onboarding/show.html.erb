<h1 class="page-title">Tutoriel de demarrage</h1>
<p class="page-subtitle">Configure tes priorites et choisis directement tes premieres missions.</p>

<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <%= form_with url: onboarding_path, method: :patch, local: true, html: { id: "onboarding-form" } do %>
      <h2 class="section-title">1. Choisis 3 categories prioritaires</h2>
      <div class="row g-2 mb-3">
        <% @categories.each do |category| %>
          <div class="col-md-4">
            <label class="shop-row shop-row--flat d-flex align-items-center gap-2">
              <%= check_box_tag "category_ids[]", category.id, @selected_ids.include?(category.id) %>
              <strong><%= category.name %></strong>
            </label>
          </div>
        <% end %>
      </div>

      <h2 class="section-title">2. Selectionne tes missions (optionnel)</h2>
      <p class="quest-meta">Tu peux en choisir jusqu'a 6 pour demarrer tout de suite.</p>

      <div id="onboarding-recommendations"
           data-quest-pool='<%= json_escape(@quest_pool.to_json) %>'
           data-empty-message="Selectionne des categories pour voir tes recommandations."
           data-selected-quest-ids='<%= @selected_quest_ids.join(",") %>'>
        <div id="onboarding-recommendations-list" class="mb-3">
          <% if @recommended_quests.any? %>
            <div class="quest-list quest-list--flat">
              <% @recommended_quests.each do |quest| %>
                <div class="quest-row quest-row--flat">
                  <label class="d-flex align-items-start gap-2 mb-0 tutorial-quest-label">
                    <%= check_box_tag "quest_ids[]", quest.id, @selected_quest_ids.include?(quest.id), class: "mt-1" %>
                    <span>
                      <strong><%= quest.title %></strong>
                      <span class="quest-meta d-block"><%= quest.category&.name || "Categorie" %> - <%= quest.xp %> XP</span>
                    </span>
                  </label>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="quest-meta mb-0">Selectionne des categories pour voir tes recommandations.</p>
          <% end %>
        </div>
      </div>

      <%= submit_tag "Terminer le tutoriel", class: "btn btn-brand" %>
    <% end %>
  </div>
</div>
