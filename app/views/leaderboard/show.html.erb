<div class="d-flex align-items-center gap-2 flex-wrap">
  <h1 class="page-title mb-0"><%= t('leaderboard.player_home.page_title', pseudo: @player.pseudo) %></h1>
  <%= hunter_rank_badge(HunterRank.for_level(@player_total_level)) %>
</div>
<p class="page-subtitle"><%= t('leaderboard.player_home.page_subtitle') %></p>

<% active_player_card = @player.respond_to?(:active_profile_card) ? @player.active_profile_card : nil %>
<% player_home_theme_class = if active_player_card.present?
                              profile_card_classes(active_player_card).to_s.gsub("profile-card-", "player-home-theme--")
                            else
                              "player-home-theme--none"
                            end %>
<% player_card_text = active_player_card.present? ? profile_card_text(@player) : nil %>

<div class="surface-card surface-card--shell player-home-shell <%= player_home_theme_class %> mb-4">
  <div class="card-body">
    <section class="hud-section mb-4 player-home-panel player-home-identity">
      <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
        <div class="d-flex align-items-center gap-3">
          <%= user_avatar_image(@player, width: 96, height: 96, css_class: "rounded-circle", alt: t('leaderboard.player_home.avatar_alt', pseudo: @player.pseudo)) %>
          <div>
            <div class="profile-frame-container <%= frame_wrapper_classes(@player.respond_to?(:active_profile_frame) ? @player.active_profile_frame : nil) %>">
              <strong><%= @player.pseudo %></strong>
            </div>
            <% if player_card_text.present? %>
              <p class="quest-meta mb-2 mt-2 player-home-identity-text"><%= player_card_text %></p>
            <% end %>
            <div class="player-home-identity-meta">
              <span class="profile-card-meta-item"><%= t('leaderboard.player_home.global_level') %> <strong><%= @player_total_level %></strong></span>
              <span class="profile-card-meta-item"><%= t('leaderboard.player_home.xp_this_week') %> <strong><%= @player_xp_this_week %></strong></span>
              <% if active_player_card.present? %>
                <span class="profile-card-meta-item"><%= t('leaderboard.player_home.active_card') %> <strong><%= active_player_card.name %></strong></span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="hud-section mb-4 player-home-panel player-home-social">
      <% unless @player == current_user %>
        <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
          <h2 class="section-title mb-0"><%= t('leaderboard.player_home.social_heading') %></h2>
          <% if @friendship_with_current.nil? %>
            <% if @player_pending_limit_reached %>
              <span class="shop-state-chip shop-state-chip--available"><%= t('leaderboard.player_home.max_pending_requests') %></span>
            <% else %>
              <%= button_to t('leaderboard.player_home.add_friend_button'), friends_path(friend_id: @player.id), method: :post, class: "btn btn-brand" %>
            <% end %>
          <% elsif @friendship_with_current.status == "accepted" %>
            <span class="shop-state-chip shop-state-chip--owned"><%= t('leaderboard.player_home.already_friend') %></span>
          <% else %>
            <span class="shop-state-chip shop-state-chip--available"><%= t('leaderboard.player_home.request_pending') %></span>
          <% end %>
        </div>
      <% else %>
        <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
          <h2 class="section-title mb-0"><%= t('leaderboard.player_home.social_heading') %></h2>
          <span class="shop-state-chip shop-state-chip--owned"><%= t('leaderboard.player_home.own_home') %></span>
        </div>
      <% end %>
    </section>

    <section class="hud-section mb-4 player-home-panel">
      <h2 class="section-title"><%= t('leaderboard.player_home.category_progress_heading') %></h2>
      <% if @player_stats.any? %>
        <% active_theme = @player.respond_to?(:active_xp_theme) ? @player.active_xp_theme : nil %>
        <% @player_stats.each do |stat| %>
          <% xp_needed = xp_needed_for_next_level(stat.level) %>
          <% percent = (stat.xp.to_f / [xp_needed, 1].max * 100).round %>
          <div class="mb-3">
            <div class="d-flex justify-content-between flex-wrap gap-2 mb-1">
              <strong><%= stat.category.name %> - <%= t('leaderboard.player_home.level_label', level: stat.level) %></strong>
              <span class="muted-label"><%= stat.xp %> / <%= xp_needed %> XP</span>
            </div>
            <div class="xp-track <%= xp_theme_classes(active_theme) %>">
              <div class="xp-fill" style="width: <%= percent %>%"></div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="alert alert-warning mb-0"><%= t('leaderboard.player_home.no_progress') %></div>
      <% end %>
    </section>

    <div class="row g-4">
      <div class="col-lg-6">
        <section class="hud-section h-100 player-home-panel">
          <h2 class="section-title"><%= t('leaderboard.player_home.weekly_quests_heading') %></h2>
          <% if @player_weekly_quests.any? %>
            <div class="quest-list quest-list--flat">
              <% @player_weekly_quests.each do |entry| %>
                <div class="quest-row quest-row--flat d-flex justify-content-between align-items-start gap-3 flex-wrap">
                  <div>
                    <strong class="player-home-item-title"><%= entry.weekly_quest.title %></strong>
                    <p class="quest-meta player-home-item-meta mb-1"><%= entry.weekly_quest.description %></p>
                    <p class="quest-meta player-home-item-meta mb-0"><%= t('leaderboard.player_home.reward_label', count: entry.weekly_quest.xp_reward) %></p>
                  </div>
                  <% if entry.completed? %>
                    <span class="shop-state-chip shop-state-chip--equipped"><%= t('leaderboard.player_home.completed_chip') %></span>
                  <% else %>
                    <span class="shop-state-chip shop-state-chip--available"><%= t('leaderboard.player_home.in_progress_chip') %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="alert alert-warning mb-0"><%= t('leaderboard.player_home.no_weekly_quest') %></div>
          <% end %>

          <hr class="hud-divider my-3">

          <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
            <h3 class="section-title mb-0"><%= t('leaderboard.player_home.active_quests_heading') %></h3>
            <% extra_active_quests = [@player_active_quests.size - 2, 0].max %>
            <% if extra_active_quests.positive? %>
              <span class="shop-state-chip shop-state-chip--available">+<%= extra_active_quests %></span>
            <% end %>
          </div>

          <% if @player_active_quests.any? %>
            <div class="quest-list quest-list--flat">
              <% @player_active_quests.first(2).each do |user_quest| %>
                <div class="quest-row quest-row--flat">
                  <strong class="player-home-item-title"><%= user_quest.quest.title %></strong>
                  <p class="quest-meta player-home-item-meta mb-0"><%= user_quest.quest.category.name %> - <%= user_quest.quest.xp %> XP</p>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="alert alert-warning mb-0"><%= t('leaderboard.player_home.no_active_quest') %></div>
          <% end %>
        </section>
      </div>

      <div class="col-lg-6">
        <section class="hud-section h-100 player-home-panel">
          <h2 class="section-title"><%= t('leaderboard.player_home.radar_heading') %></h2>
          <% if @player_stats_data.any? %>
            <div class="stats-chart-wrap mb-4">
              <canvas
                id="statsChart"
                data-stats='<%= @player_stats_data.to_json %>'
                data-total-level="<%= @player_total_level %>">
              </canvas>
            </div>
          <% else %>
            <div class="alert alert-warning mb-4"><%= t('leaderboard.player_home.no_chart_data') %></div>
          <% end %>

          <h2 class="section-title"><%= t('leaderboard.player_home.recent_quests_heading') %></h2>
          <% if @recent_quests.any? %>
            <div class="quest-list quest-list--flat">
              <% @recent_quests.each do |user_quest| %>
                <div class="quest-row quest-row--flat">
                  <strong class="player-home-item-title"><%= user_quest.quest.title %></strong>
                  <p class="quest-meta player-home-item-meta mb-0"><%= t('leaderboard.player_home.finished_on', date: user_quest.updated_at.strftime("%d/%m/%Y")) %></p>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="alert alert-warning mb-0"><%= t('leaderboard.player_home.no_recent_quest') %></div>
          <% end %>
        </section>
      </div>
    </div>

    <section class="hud-section mt-4 player-home-panel">
      <h2 class="section-title"><%= t('leaderboard.player_home.most_completed_heading') %></h2>
      <% if @most_completed_quests.any? %>
        <div class="quest-list quest-list--flat">
          <% @most_completed_quests.each do |user_quest| %>
            <div class="quest-row quest-row--flat">
              <strong class="player-home-item-title"><%= user_quest.quest.title %></strong>
              <p class="quest-meta player-home-item-meta mb-0"><%= t('leaderboard.player_home.last_completion', date: user_quest.last_completed_at.to_date.strftime("%d/%m/%Y")) %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="alert alert-warning mb-0"><%= t('leaderboard.player_home.no_popular_quest') %></div>
      <% end %>
    </section>

    <div class="mt-4 d-flex align-items-center gap-2 flex-wrap">
      <span class="shop-state-chip shop-state-chip--owned"><%= t('leaderboard.player_home.total_completed', count: @player_completed_quests_total) %></span>
      <%= link_to t('leaderboard.player_home.back_to_leaderboard'), leaderboard_index_path, class: "btn btn-outline-quest" %>
    </div>
  </div>
</div>
