<h1 class="page-title">Profil de <%= @player.pseudo %></h1>

<div class="surface-card surface-card--shell">
  <div class="card-body">
    <section class="hud-section text-center mb-4">
      <%= user_avatar_image(@player, width: 150, height: 150, css_class: "rounded-circle", alt: "Avatar de #{@player.pseudo}") %>

      <% unless @player == current_user %>
        <div class="mt-3">
          <% if @friendship_with_current.nil? %>
            <% if @player_pending_limit_reached %>
              <span class="shop-state-chip shop-state-chip--available">Ce joueur a atteint le nombre max de demandes d'amis en attente.</span>
            <% else %>
              <%= button_to "Demander en ami", friends_path(friend_id: @player.id), method: :post, class: "btn btn-brand" %>
            <% end %>
          <% elsif @friendship_with_current.status == "accepted" %>
            <span class="shop-state-chip shop-state-chip--owned">Deja ami</span>
          <% else %>
            <span class="shop-state-chip shop-state-chip--available">Demande deja en attente</span>
          <% end %>
        </div>
      <% end %>
    </section>

    <section class="hud-section">
      <h3 class="section-title">Statistiques</h3>
      <% if @top_categories.any? %>
        <ul class="list-group surface-list">
          <% @top_categories.each do |stat| %>
            <li class="list-group-item"><strong><%= stat.category.name %></strong> : Niveau <%= stat.level %> | XP : <%= stat.xp %></li>
          <% end %>
        </ul>
      <% else %>
        <p>Aucune statistique disponible.</p>
      <% end %>
    </section>

    <section class="hud-section mt-4">
      <h3 class="section-title">Quêtes les plus réalisées</h3>
      <% if @most_completed_quests.any? %>
        <ul class="list-group surface-list">
          <% @most_completed_quests.each do |user_quest| %>
            <li class="list-group-item">
              <strong><%= user_quest.quest.title %></strong> - Complétée <%= user_quest.completed_count %> fois
            </li>
          <% end %>
        </ul>
      <% else %>
        <p>Aucune quête populaire.</p>
      <% end %>
    </section>

    <section class="hud-section mt-4">
      <h3 class="section-title">Dernières quêtes réalisées</h3>
      <% if @recent_quests.any? %>
        <ul class="list-group surface-list">
          <% @recent_quests.each do |user_quest| %>
            <li class="list-group-item">
              <strong><%= user_quest.quest.title %></strong> - Terminé le <%= user_quest.updated_at.strftime("%d/%m/%Y") %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p>Aucune quête récente.</p>
      <% end %>
    </section>

    <div class="mt-4">
      <%= link_to "Retour au classement", leaderboard_index_path, class: "btn btn-secondary" %>
    </div>
  </div>
</div>
