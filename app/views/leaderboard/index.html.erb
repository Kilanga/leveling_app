<h1 class="page-title">Classement ligue hebdomadaire</h1>

<div class="surface-card surface-card--shell">
  <div class="card-body">
    <section class="hud-section">
      <%= form_with url: leaderboard_index_path, method: :get, local: true, class: "mb-3 mobile-stack" do %>
        <div class="row align-items-end g-2">
          <div class="col-md-6">
            <%= select_tag :category_id, options_from_collection_for_select(Category.all, :id, :name, params[:category_id].presence), include_blank: "Toutes les catégories", class: "form-select" %>
          </div>
          <div class="col-md-6">
            <%= submit_tag "Filtrer", class: "btn btn-brand" %>
          </div>
        </div>
      <% end %>

      <p class="quest-meta mb-1">Ligue actuelle: <strong><%= @current_league_name %></strong></p>
      <p class="quest-meta mb-3">Classement complet de ta ligue pour le filtre selectionne. Tu peux scroller pour voir toute la liste.</p>

      <h2 class="section-title">Classement ligue hebdomadaire (filtre actif)</h2>
      <div class="table-responsive league-table-scroll">
        <table class="table">
          <thead>
            <tr>
              <th>Rang</th>
              <th>Avatar</th>
              <th>Joueur</th>
              <th>XP semaine</th>
              <th>Ligue</th>
            </tr>
          </thead>
          <tbody>
            <% if @league_standings.any? %>
              <% @league_standings.each do |entry| %>
                <tr class="<%= 'table-active' if entry[:user].id == current_user.id %>">
                  <td>#<%= entry[:rank] %></td>
                  <td>
                    <%= user_avatar_image(entry[:user], width: 44, height: 44, css_class: "rounded-circle", alt: "Avatar de #{entry[:user].pseudo}") %>
                  </td>
                  <td>
                    <%= link_to entry[:user].pseudo, leaderboard_path(entry[:user]), class: "text-primary text-decoration-none fw-bold" %>
                    <% if entry[:user].active_title %>
                      <span class="badge bg-<%= entry[:user].title_rarity_class %>"><%= entry[:user].active_title.name %></span>
                    <% end %>
                    <% if entry[:user].id == current_user.id %>
                      <span class="badge text-bg-dark ms-1">Toi</span>
                    <% end %>
                  </td>
                  <td><%= entry[:weekly_xp] %></td>
                  <td><%= entry[:tier] %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="text-center">Aucune donnee de ligue disponible.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</div>
