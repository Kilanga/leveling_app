<h1 class="page-title">Classement ligue hebdomadaire</h1>

<div class="surface-card surface-card--shell">
  <div class="card-body">
    <section class="hud-section">
      <p class="quest-meta mb-1">Ligue actuelle: <strong><%= @current_league_name %></strong></p>
      <p class="quest-meta mb-1">Prochain reset ligue: <strong><%= l(@next_league_settlement_at, format: :long) %></strong></p>
      <p class="quest-meta mb-3">Dans <strong><%= @league_settlement_countdown %></strong>. Classement complet de ta ligue, avec mise a jour au chargement de la page.</p>
      <% if @league_standings.size < WeeklyLeague::MIN_MOVEMENT_COHORT_SIZE %>
        <p class="quest-meta mb-3 league-movement-hint">
          Mouvement de ligue fige pour le moment: cohorte <strong><%= @league_standings.size %>/<%= WeeklyLeague::MIN_MOVEMENT_COHORT_SIZE %></strong>.
          Les promotions/relegations s'activent des 3 joueurs.
        </p>
      <% end %>

      <h2 class="section-title">Classement ligue hebdomadaire</h2>
      <div class="table-responsive league-table-scroll">
        <table class="table">
          <thead>
            <tr>
              <th>Rang</th>
              <th>Avatar</th>
              <th>Joueur</th>
              <th>XP semaine</th>
              <th>Ligue</th>
            </tr>
          </thead>
          <tbody>
            <% if @league_standings.any? %>
              <% @league_standings.each do |entry| %>
                <tr class="<%= 'league-current-user-row' if entry[:user].id == current_user.id %>">
                  <td>
                    #<%= entry[:rank] %>
                    <% if entry[:projected_movement].to_i > 0 %>
                      <span class="league-trend league-trend--up" aria-label="Promotion projetee" title="Promotion projetee">▲</span>
                      <span class="league-movement-label league-movement-label--up">Montee</span>
                    <% elsif entry[:projected_movement].to_i < 0 %>
                      <span class="league-trend league-trend--down" aria-label="Relegation projetee" title="Relegation projetee">▼</span>
                      <span class="league-movement-label league-movement-label--down">Descente</span>
                    <% else %>
                      <span class="league-trend league-trend--hold" aria-label="Maintien projete" title="Maintien projete">•</span>
                      <span class="league-movement-label league-movement-label--hold">Maintien</span>
                    <% end %>
                  </td>
                  <td>
                    <%= user_avatar_image(entry[:user], width: 44, height: 44, css_class: "rounded-circle", alt: "Avatar de #{entry[:user].pseudo}") %>
                  </td>
                  <td>
                    <div class="leaderboard-player-meta">
                      <span class="profile-frame-container <%= frame_wrapper_classes(entry[:user].active_profile_frame) %>">
                        <%= link_to entry[:user].pseudo, leaderboard_path(entry[:user]), class: "text-decoration-none" %>
                      </span>
                      <% if entry[:user].active_title %>
                        <span class="badge bg-<%= entry[:user].title_rarity_class %>"><%= entry[:user].active_title.name %></span>
                      <% end %>
                      <% if entry[:user].id == current_user.id %>
                        <span class="badge text-bg-dark">Toi</span>
                      <% end %>
                    </div>
                  </td>
                  <td><%= entry[:weekly_xp] %></td>
                  <td><%= entry[:tier] %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="text-center">Aucune donnee de ligue disponible.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</div>
