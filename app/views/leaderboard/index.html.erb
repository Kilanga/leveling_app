<h1 class="page-title"><%= t('leaderboard.index.page_title') %></h1>

<div class="surface-card surface-card--shell">
  <div class="card-body">
    <section class="hud-section">
      <p class="quest-meta mb-1"><%= t('leaderboard.index.current_league') %> <strong><%= @current_league_name %></strong></p>
      <p class="quest-meta mb-1"><%= t('leaderboard.index.next_reset') %> <strong><%= l(@next_league_settlement_at, format: :long) %></strong></p>
      <p class="quest-meta mb-3"><%= t('leaderboard.index.countdown_hint', countdown: @league_settlement_countdown).html_safe %></p>
      <% if @league_standings.size < WeeklyLeague::MIN_MOVEMENT_COHORT_SIZE %>
        <p class="quest-meta mb-3 league-movement-hint">
          Mouvement de ligue fige pour le moment: cohorte <strong><%= @league_standings.size %>/<%= WeeklyLeague::ROOM_CAPACITY %></strong>.
          <%= t('leaderboard.index.movement_hint', count: WeeklyLeague::MIN_MOVEMENT_COHORT_SIZE) %>
        </p>
      <% end %>

      <h2 class="section-title"><%= t('leaderboard.index.table_heading') %></h2>
      <div class="table-responsive league-table-scroll">
        <table class="table">
          <thead>
            <tr>
              <th><%= t('leaderboard.index.th_rank') %></th>
              <th><%= t('leaderboard.index.th_avatar') %></th>
              <th><%= t('leaderboard.index.th_player') %></th>
              <th><%= t('leaderboard.index.th_week_xp') %></th>
              <th><%= t('leaderboard.index.th_league') %></th>
            </tr>
          </thead>
          <tbody>
            <% if @league_standings.any? %>
              <% @league_standings.each do |entry| %>
                <tr class="<%= 'league-current-user-row' if entry[:user].id == current_user.id %>">
                  <td>
                    #<%= entry[:rank] %>
                    <% if entry[:projected_movement].to_i > 0 %>
                      <span class="league-trend league-trend--up" aria-label="<%= t('leaderboard.index.promotion_projected') %>" title="<%= t('leaderboard.index.promotion_projected') %>">▲</span>
                      <span class="league-movement-label league-movement-label--up"><%= t('leaderboard.index.up_label') %></span>
                    <% elsif entry[:projected_movement].to_i < 0 %>
                      <span class="league-trend league-trend--down" aria-label="<%= t('leaderboard.index.relegation_projected') %>" title="<%= t('leaderboard.index.relegation_projected') %>">▼</span>
                      <span class="league-movement-label league-movement-label--down"><%= t('leaderboard.index.down_label') %></span>
                    <% else %>
                      <span class="league-trend league-trend--hold" aria-label="<%= t('leaderboard.index.hold_projected') %>" title="<%= t('leaderboard.index.hold_projected') %>">•</span>
                      <span class="league-movement-label league-movement-label--hold"><%= t('leaderboard.index.hold_label') %></span>
                    <% end %>
                  </td>
                  <td>
                    <%= user_avatar_image(entry[:user], width: 44, height: 44, css_class: "rounded-circle", alt: t('leaderboard.index.avatar_alt', pseudo: entry[:user].pseudo)) %>
                  </td>
                  <td>
                    <div class="leaderboard-player-meta">
                      <span class="profile-frame-container <%= frame_wrapper_classes(entry[:user].active_profile_frame) %>">
                        <%= link_to entry[:user].pseudo, leaderboard_path(entry[:user]), class: "text-decoration-none" %>
                        <%= hunter_rank_badge(HunterRank.for_level(entry[:total_level] || 0)) if entry.key?(:total_level) %>
                      </span>
                      <% if entry[:user].active_title %>
                        <span class="badge bg-<%= entry[:user].title_rarity_class %>"><%= entry[:user].active_title.name %></span>
                      <% end %>
                      <% if entry[:user].id == current_user.id %>
                        <span class="badge text-bg-dark"><%= t('leaderboard.index.you_badge') %></span>
                      <% end %>
                    </div>
                  </td>
                  <td><%= entry[:weekly_xp] %></td>
                  <td><%= entry[:tier] %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="text-center"><%= t('leaderboard.index.no_data') %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</div>

<% if @current_season %>
  <div class="surface-card surface-card--shell mt-4" id="season-leaderboard">
    <div class="card-body">
      <section class="hud-section">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-2">
          <div>
            <h2 class="section-title mb-1"><%= t('leaderboard.season.heading', name: @current_season.name) %></h2>
            <p class="quest-meta mb-0"><%= t('leaderboard.season.subtitle') %></p>
          </div>
          <span class="shop-state-chip shop-state-chip--available">
            <%= t('leaderboard.season.days_remaining', count: @season_days_remaining) %>
          </span>
        </div>

        <p class="quest-meta mb-3">
          <% if @my_season_rank %>
            <%= t('leaderboard.season.my_rank', rank: @my_season_rank, xp: @my_season_entry&.xp.to_i) %>
          <% else %>
            <%= t('leaderboard.season.no_rank_yet') %>
          <% end %>
          <%= t('leaderboard.season.rewards_hint') %>
        </p>

        <% if @season_entries.any? %>
          <div class="table-responsive league-table-scroll">
            <table class="table">
              <thead>
                <tr>
                  <th><%= t('leaderboard.index.th_rank') %></th>
                  <th><%= t('leaderboard.index.th_player') %></th>
                  <th><%= t('leaderboard.season.th_season_xp') %></th>
                </tr>
              </thead>
              <tbody>
                <% @season_entries.each_with_index do |entry, index| %>
                  <tr class="<%= 'league-current-user-row' if entry.user_id == current_user.id %>">
                    <td>
                      #<%= index + 1 %>
                      <% if index < SeasonManager::TOP_TITLE_COUNT %>
                        <span title="<%= t('leaderboard.season.top3_tooltip') %>">👑</span>
                      <% end %>
                    </td>
                    <td>
                      <div class="leaderboard-player-meta">
                        <%= link_to entry.user.pseudo, leaderboard_path(entry.user), class: "text-decoration-none" %>
                        <% if entry.user.active_title %>
                          <span class="badge bg-<%= entry.user.title_rarity_class %>"><%= entry.user.active_title.name %></span>
                        <% end %>
                        <% if entry.user_id == current_user.id %>
                          <span class="badge text-bg-dark"><%= t('leaderboard.index.you_badge') %></span>
                        <% end %>
                      </div>
                    </td>
                    <td><%= entry.xp %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="alert alert-warning mb-0"><%= t('leaderboard.season.empty') %></div>
        <% end %>
      </section>
    </div>
  </div>
<% end %>
