<h1 class="page-title">Classement des joueurs</h1>

<div class="surface-card surface-card--shell">
  <div class="card-body">
    <section class="hud-section">
      <%= form_with url: leaderboard_index_path, method: :get, local: true, class: "mb-3 mobile-stack" do %>
        <div class="row align-items-end g-2">
          <div class="col-md-6">
            <%= select_tag :category_id, options_from_collection_for_select(Category.all, :id, :name, params[:category_id].presence), include_blank: "Toutes les catégories", class: "form-select" %>
          </div>
          <div class="col-md-6">
            <%= submit_tag "Filtrer", class: "btn btn-brand" %>
          </div>
        </div>
      <% end %>

      <p class="quest-meta mb-3">Affichage limite aux 10 premiers joueurs pour le filtre selectionne.</p>

      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Rang</th>
              <th>Avatar</th>
              <th>Pseudo</th>
              <th>XP Total</th>
              <th>Ligue hebdo</th>
            </tr>
          </thead>
          <tbody>
            <% if @players.any? %>
              <% @players.each_with_index do |player, index| %>
                <tr>
                  <td>#<%= index + 1 %></td>
                  <td>
                    <%= user_avatar_image(player, width: 50, height: 50, css_class: "rounded-circle", alt: "Avatar de #{player.pseudo}") %>
                  </td>
                  <td>
                    <%= link_to player.pseudo, leaderboard_path(player), class: "text-primary text-decoration-none fw-bold" %>
                    <% if player.active_title %>
                      <span class="badge bg-<%= player.title_rarity_class %>"><%= player.active_title.name %></span>
                    <% end %>
                  </td>
                  <td><%= player.total_xp_sum.to_i %></td>
                  <td><%= @league_by_user_id.dig(player.id, :tier) || "Bronze" %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="text-center">Aucun joueur trouve.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <hr class="hud-divider">

    <section class="hud-section">
      <h2 class="section-title">Top ligue hebdomadaire (filtre actif)</h2>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Rang</th>
              <th>Joueur</th>
              <th>XP semaine</th>
              <th>Ligue</th>
            </tr>
          </thead>
          <tbody>
            <% if @league_standings.any? %>
              <% @league_standings.each do |entry| %>
                <tr>
                  <td>#<%= entry[:rank] %></td>
                  <td><%= link_to entry[:user].pseudo, leaderboard_path(entry[:user]), class: "text-primary text-decoration-none fw-bold" %></td>
                  <td><%= entry[:weekly_xp] %></td>
                  <td><%= entry[:tier] %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="text-center">Aucune donnee de ligue disponible.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</div>
