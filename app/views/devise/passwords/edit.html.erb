<div class="auth-shell">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-7 col-lg-5">
        <div class="surface-card surface-card--shell auth-card">
          <div class="card-body">
            <h1 class="page-title auth-title"><%= t('devise.passwords.edit.title') %></h1>
            <p class="page-subtitle auth-subtitle"><%= t('devise.passwords.edit.subtitle') %></p>

            <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
              <%= render "devise/shared/error_messages", resource: resource %>
              <%= f.hidden_field :reset_password_token %>

              <div class="mb-3">
                <%= f.label :password, t('devise.passwords.edit.new_password_label'), class: "form-label" %>
                <% if @minimum_password_length %>
                  <p class="quest-meta mb-2"><%= t('devise.passwords.edit.min_password_notice', count: @minimum_password_length) %></p>
                <% end %>
                <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-control", placeholder: "••••••••" %>
              </div>

              <div class="mb-3">
                <%= f.label :password_confirmation, t('devise.passwords.edit.password_confirmation_label'), class: "form-label" %>
                <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "••••••••" %>
              </div>

              <div class="d-grid mb-3">
                <%= f.submit t('devise.passwords.edit.update_button'), class: "btn btn-brand btn-arcade" %>
              </div>
            <% end %>

            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
