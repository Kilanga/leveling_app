<div class="auth-shell">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-7 col-lg-5">
        <div class="surface-card surface-card--shell auth-card">
          <div class="card-body">
            <h1 class="page-title auth-title"><%= t('devise.confirmations.new.title') %></h1>
            <p class="page-subtitle auth-subtitle"><%= t('devise.confirmations.new.subtitle') %></p>

            <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
              <%= render "devise/shared/error_messages", resource: resource %>

              <div class="mb-3">
                <%= f.label :email, t('common.email'), class: "form-label" %>
                <%= f.email_field :email, autofocus: true, autocomplete: "email", value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email), class: "form-control", placeholder: t('devise.confirmations.new.email_placeholder') %>
              </div>

              <div class="d-grid mb-3">
                <%= f.submit t('devise.confirmations.new.send_button'), class: "btn btn-brand btn-arcade" %>
              </div>
            <% end %>

            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
