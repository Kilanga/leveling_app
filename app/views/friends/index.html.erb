<h1 class="page-title"><%= t('friends.index.page_title') %></h1>
<p class="page-subtitle"><%= t('friends.index.page_subtitle') %></p>

<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <h2 class="section-title"><%= t('friends.index.active_friends_heading') %></h2>
    <% if @friends.any? %>
      <div class="quest-list quest-list--flat">
        <% @friends.each do |friend| %>
          <div class="quest-row quest-row--flat friend-row">
            <strong><%= friend.pseudo %></strong>
            <div class="friend-row__actions">
              <%= button_to t('friends.index.challenge_button'), friend_challenges_path(friend_id: friend.id), method: :post, class: "btn btn-sm btn-brand" %>
              <%= button_to t('friends.index.remove_button'), friend_path(friend), method: :delete, class: "btn btn-sm btn-outline-secondary" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="quest-meta mb-0"><%= t('friends.index.no_friends') %></p>
    <% end %>
  </div>
</div>

<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <h2 class="section-title"><%= t('friends.index.active_challenges_heading') %></h2>
    <% if @active_friend_challenges.any? %>
      <div class="quest-list quest-list--flat">
        <% @active_friend_challenges.each do |challenge| %>
          <% opponent = challenge.opponent_for(current_user) %>
          <div class="quest-row quest-row--flat friend-row">
            <div>
              <strong><%= t('friends.index.versus') %> <%= opponent.pseudo %></strong>
              <p class="quest-meta mb-0"><%= t('friends.index.ends_on', date: l(challenge.ends_at, format: :short)) %></p>
            </div>
            <span class="shop-state-chip shop-state-chip--best"><%= t('friends.index.xp_label', count: challenge.xp_gain_for(current_user)) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="quest-meta mb-0"><%= t('friends.index.no_active_challenge') %></p>
    <% end %>
  </div>
</div>

<div class="surface-card surface-card--shell mb-4">
  <div class="card-body d-flex justify-content-between align-items-start gap-3 flex-wrap">
    <div>
      <h2 class="section-title mb-1"><%= t('friends.index.referral_heading') %></h2>
      <p class="quest-meta mb-2"><%= t('friends.index.referral_hint', invitee: @referral_invitee_reward, inviter: @referral_inviter_reward) %></p>
      <input type="text" class="form-control invite-link-input" value="<%= @invite_url %>" readonly>
    </div>
    <a href="https://twitter.com/intent/tweet?text=<%= ERB::Util.url_encode(t('friends.index.share_text')) %>&url=<%= ERB::Util.url_encode(@invite_url) %>" target="_blank" rel="noopener" class="btn btn-sm btn-outline-quest">
      <%= t('friends.index.share_button') %>
    </a>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="surface-card surface-card--shell h-100">
      <div class="card-body">
        <h2 class="section-title"><%= t('friends.index.received_requests_heading') %></h2>
        <% if @pending_received_requests&.any? %>
          <div class="quest-list quest-list--flat">
            <% @pending_received_requests.each do |friend| %>
              <div class="quest-row quest-row--flat friend-row">
                <div>
                  <strong><%= friend.pseudo %></strong>
                  <p class="quest-meta mb-0"><%= t('friends.index.awaiting_reply') %></p>
                </div>
                <div class="friend-row__actions">
                  <%= button_to t('friends.index.accept_button'), accept_friend_path(friend), method: :post, class: "btn btn-sm btn-brand" %>
                  <%= button_to t('friends.index.reject_button'), reject_friend_path(friend), method: :delete, class: "btn btn-sm btn-outline-secondary" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="quest-meta mb-0"><%= t('friends.index.no_pending_request') %></p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="surface-card surface-card--shell h-100">
      <div class="card-body">
        <h2 class="section-title"><%= t('friends.index.sent_requests_heading') %></h2>
        <% if @pending_sent_requests.any? %>
          <div class="quest-list quest-list--flat">
            <% @pending_sent_requests.each do |friend| %>
              <div class="quest-row quest-row--flat friend-row">
                <div>
                  <strong><%= friend.pseudo %></strong>
                  <p class="quest-meta mb-0"><%= t('friends.index.invitation_sent') %></p>
                </div>
                <div class="friend-row__actions">
                  <%= button_to t('friends.index.cancel_button'), reject_friend_path(friend), method: :delete, class: "btn btn-sm btn-outline-secondary" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="quest-meta mb-0"><%= t('friends.index.no_pending_request') %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="surface-card surface-card--shell mt-4">
  <div class="card-body">
    <h2 class="section-title"><%= t('friends.index.search_heading') %></h2>
    <%= form_with url: search_friends_path, method: :get, local: true, class: "friend-search-form" do |form| %>
      <%= form.label :query, t('friends.index.search_label'), class: "quest-meta mb-1" %>
      <%= form.text_field :query, class: "form-control", placeholder: t('friends.index.search_placeholder') %>
      <%= form.submit t('friends.index.search_button'), class: "btn btn-brand mt-2" %>
    <% end %>

    <% if @users %>
      <h3 class="section-title mt-4"><%= t('friends.index.results_heading') %></h3>
      <% if @users.any? %>
        <div class="quest-list quest-list--flat">
          <% @users.each do |user| %>
            <div class="quest-row quest-row--flat friend-row">
              <strong><%= user.pseudo %></strong>
              <% unless current_user.friends.include?(user) %>
                <%= button_to t('friends.index.send_request_button'), friends_path(friend_id: user.id), method: :post, class: "btn btn-sm btn-brand" %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="quest-meta mb-0"><%= t('friends.index.no_player_found') %></p>
      <% end %>
    <% end %>
  </div>
</div>

<div class="surface-card surface-card--shell mt-4">
  <div class="card-body">
    <section class="hud-section">
      <h2 class="section-title mt-1"><%= t('friends.index.friends_most_completed_heading') %></h2>
      <% if @most_completed_quests.any? %>
        <ul class="list-group surface-list">
          <% @most_completed_quests.each do |quest| %>
            <li class="list-group-item">
              <strong><%= quest.quest.title %></strong> - <%= t('friends.index.completed_times_by', count: quest.completed_count) %>
              <%= link_to quest.user.pseudo, leaderboard_path(quest.user), class: "text-primary fw-bold" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="quest-meta mb-0"><%= t('friends.index.no_popular_quest') %></p>
      <% end %>
    </section>

    <section class="hud-section mt-4">
      <h2 class="section-title"><%= t('friends.index.friends_recent_heading') %></h2>
      <% if @recent_quests.any? %>
        <ul class="list-group surface-list">
          <% @recent_quests.each do |user_quest| %>
            <li class="list-group-item">
              <strong><%= user_quest.quest.title %></strong> - <%= t('friends.index.finished_on_by', date: user_quest.updated_at.strftime("%d/%m/%Y")) %>
              <%= link_to user_quest.user.pseudo, leaderboard_path(user_quest.user), class: "text-primary fw-bold" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="quest-meta mb-0"><%= t('friends.index.no_recent_quest') %></p>
      <% end %>
    </section>
  </div>
</div>
