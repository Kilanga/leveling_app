<h1 class="page-title">Liste de mes amis</h1>
<p class="page-subtitle">Gere ton cercle, tes invitations et tes defis actifs.</p>

<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <h2 class="section-title">Amis actifs</h2>
    <% if @friends.any? %>
      <div class="quest-list quest-list--flat">
        <% @friends.each do |friend| %>
          <div class="quest-row quest-row--flat friend-row">
            <strong><%= friend.pseudo %></strong>
            <div class="friend-row__actions">
              <%= button_to "Lancer un defi 48h", friend_challenges_path(friend_id: friend.id), method: :post, class: "btn btn-sm btn-brand" %>
              <%= button_to "Retirer", friend_path(friend), method: :delete, class: "btn btn-sm btn-outline-secondary" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="quest-meta mb-0">Tu n'as pas encore d'amis.</p>
    <% end %>
  </div>
</div>

<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <h2 class="section-title">Defis actifs</h2>
    <% if @active_friend_challenges.any? %>
      <div class="quest-list quest-list--flat">
        <% @active_friend_challenges.each do |challenge| %>
          <% opponent = challenge.opponent_for(current_user) %>
          <div class="quest-row quest-row--flat friend-row">
            <div>
              <strong>Contre <%= opponent.pseudo %></strong>
              <p class="quest-meta mb-0">Se termine le <%= l(challenge.ends_at, format: :short) %></p>
            </div>
            <span class="shop-state-chip shop-state-chip--best">XP: <%= challenge.xp_gain_for(current_user) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="quest-meta mb-0">Aucun defi actif.</p>
    <% end %>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="surface-card surface-card--shell h-100">
      <div class="card-body">
        <h2 class="section-title">Demandes recues</h2>
        <% if @pending_received_requests&.any? %>
          <div class="quest-list quest-list--flat">
            <% @pending_received_requests.each do |friend| %>
              <div class="quest-row quest-row--flat friend-row">
                <div>
                  <strong><%= friend.pseudo %></strong>
                  <p class="quest-meta mb-0">En attente de ta reponse</p>
                </div>
                <div class="friend-row__actions">
                  <%= button_to "Accepter", accept_friend_path(friend), method: :post, class: "btn btn-sm btn-brand" %>
                  <%= button_to "Refuser", reject_friend_path(friend), method: :delete, class: "btn btn-sm btn-outline-secondary" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="quest-meta mb-0">Aucune demande en attente.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="surface-card surface-card--shell h-100">
      <div class="card-body">
        <h2 class="section-title">Demandes envoyees</h2>
        <% if @pending_sent_requests.any? %>
          <div class="quest-list quest-list--flat">
            <% @pending_sent_requests.each do |friend| %>
              <div class="quest-row quest-row--flat friend-row">
                <div>
                  <strong><%= friend.pseudo %></strong>
                  <p class="quest-meta mb-0">Invitation envoyee</p>
                </div>
                <div class="friend-row__actions">
                  <%= button_to "Annuler", reject_friend_path(friend), method: :delete, class: "btn btn-sm btn-outline-secondary" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="quest-meta mb-0">Aucune demande en attente.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="surface-card surface-card--shell mt-4">
  <div class="card-body">
    <h2 class="section-title">Rechercher un ami</h2>
    <%= form_with url: search_friends_path, method: :get, local: true, class: "friend-search-form" do |form| %>
      <%= form.label :query, "Rechercher par pseudo", class: "quest-meta mb-1" %>
      <%= form.text_field :query, class: "form-control", placeholder: "Pseudo du joueur" %>
      <%= form.submit "Rechercher", class: "btn btn-brand mt-2" %>
    <% end %>

    <% if @users %>
      <h3 class="section-title mt-4">Resultats</h3>
      <% if @users.any? %>
        <div class="quest-list quest-list--flat">
          <% @users.each do |user| %>
            <div class="quest-row quest-row--flat friend-row">
              <strong><%= user.pseudo %></strong>
              <% unless current_user.friends.include?(user) %>
                <%= button_to "Envoyer une demande", friends_path(friend_id: user.id), method: :post, class: "btn btn-sm btn-brand" %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="quest-meta mb-0">Aucun joueur trouve.</p>
      <% end %>
    <% end %>
  </div>
</div>

<div class="surface-card surface-card--shell mt-4">
  <div class="card-body">
    <section class="hud-section">
      <h2 class="section-title mt-1">Quetes les plus realisees par mes amis</h2>
      <% if @most_completed_quests.any? %>
        <ul class="list-group surface-list">
          <% @most_completed_quests.each do |quest| %>
            <li class="list-group-item">
              <strong><%= quest.quest.title %></strong> - Completee <%= quest.completed_count %> fois par
              <%= link_to quest.user.pseudo, leaderboard_path(quest.user), class: "text-primary fw-bold" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="quest-meta mb-0">Aucune quete populaire chez tes amis.</p>
      <% end %>
    </section>

    <section class="hud-section mt-4">
      <h2 class="section-title">Dernieres quetes realisees par mes amis</h2>
      <% if @recent_quests.any? %>
        <ul class="list-group surface-list">
          <% @recent_quests.each do |user_quest| %>
            <li class="list-group-item">
              <strong><%= user_quest.quest.title %></strong> - Termine le <%= user_quest.updated_at.strftime("%d/%m/%Y") %> par
              <%= link_to user_quest.user.pseudo, leaderboard_path(user_quest.user), class: "text-primary fw-bold" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="quest-meta mb-0">Aucune quete recente.</p>
      <% end %>
    </section>
  </div>
</div>
