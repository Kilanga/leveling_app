<h1 class="page-title">Profil de <%= @user.pseudo %></h1>

<!-- Conteneur responsive -->
<div class="row align-items-center g-4">
  <!-- Avatar (colonne gauche) -->
  <div class="col-md-4 text-center">
    <%= user_avatar_image(@user, width: 250, height: 250, css_class: "rounded-circle", alt: "Avatar de #{@user.pseudo}") %>
  </div>

  <!-- Actions compte (colonne droite) -->
  <div class="col-md-8">
    <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
      <%= link_to "Modifier mon mot de passe", edit_user_registration_path, class: "btn btn-outline-quest" %>
      <%= form_with url: update_pseudo_path, method: :patch, local: true, class: "d-flex flex-wrap gap-2 align-items-center" do %>
        <%= text_field_tag "user[pseudo]", nil, class: "form-control", placeholder: "Nouveau pseudo", style: "max-width: 240px;", minlength: 3, maxlength: 22 %>
        <%= submit_tag "Changer mon pseudo", class: "btn btn-outline-quest" %>
      <% end %>
    </div>

    <% if @next_pseudo_change_at.present? %>
      <p class="text-muted small mt-1 mb-0">Prochain changement de pseudo possible le <%= @next_pseudo_change_at.strftime("%d/%m/%Y") %>.</p>
    <% end %>
    <p class="text-muted small mt-1 mb-0">Le pseudo peut etre modifie une fois par semaine.</p>
  </div>
</div>

<!-- Gestion des titres -->
<h2 class="section-title mt-4">Mes Titres</h2>
<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <p class="mb-2">
      <span class="shop-rarity-text shop-rarity-text--common">Titre actuel:</span>
      <% if @user.active_title.present? %>
        <span class="badge bg-<%= @user.title_rarity_class %>"><%= @user.active_title.name %></span>
      <% else %>
        <strong class="text-white">Aucun titre actif</strong>
      <% end %>
    </p>
    
    <% if @owned_titles.any? %>
      <div class="d-flex flex-wrap gap-2">
        <% @owned_titles.each do |title| %>
          <% is_active = @user.active_title_id == title.id %>
          <% badge_class = case title.rarity
                          when "rare" then "primary"
                          when "epic" then "purple"
                          when "legendary" then "warning"
                          else "secondary"
                          end %>
          <% if is_active %>
            <span class="badge bg-<%= badge_class %>"><%= title.name %></span>
          <% else %>
            <span class="btn btn-sm btn-outline-quest" style="pointer-events: none;"><%= title.name %></span>
            <%= button_to "Equiper", activate_title_path, method: :post, params: { shop_item_id: title.id }, class: "btn btn-sm btn-brand" %>
          <% end %>
        <% end %>
        
        <% if @user.active_title.present? %>
          <%= link_to "Retirer le titre", deactivate_title_path, method: :post, class: "btn btn-sm btn-outline-secondary" %>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted small">Aucun titre disponible pour le moment. Gagnez-les en boutique!</p>
    <% end %>
  </div>
</div>

<h2 class="section-title mt-4">Titres Communs Gratuits</h2>
<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <div class="shop-list shop-list--flat">
      <% @common_unlockable_titles.each do |entry| %>
        <div class="shop-row shop-row--flat">
          <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
            <strong class="shop-rarity-text shop-rarity-text--common"><%= entry[:name] %></strong>
            <span class="rarity-chip rarity-chip--common">Common</span>
          </div>
          <p class="quest-meta mb-1"><%= entry[:description] %></p>
          <p class="quest-meta mb-2">Objectif: <%= entry[:objective] %></p>

          <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
            <% if entry[:owned] %>
              <span class="shop-state-chip shop-state-chip--owned">Debloque</span>
              <% if entry[:active] %>
                <span class="shop-state-chip shop-state-chip--equipped">Equipe</span>
              <% else %>
                <%= button_to "Equiper", activate_title_path, method: :post, params: { shop_item_id: entry[:id] }, class: "btn btn-sm btn-brand" %>
              <% end %>
            <% else %>
              <span class="shop-state-chip shop-state-chip--available">Bloque</span>
              <span class="quest-meta">Objectif non atteint</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<h2 class="section-title mt-4">Titres Prestige Gratuits</h2>
<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <div class="shop-list shop-list--flat">
      <% @prestige_unlockable_titles.each do |entry| %>
        <div class="shop-row shop-row--flat">
          <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
            <strong class="shop-rarity-text shop-rarity-text--<%= entry[:rarity] %>"><%= entry[:name] %></strong>
            <span class="rarity-chip rarity-chip--<%= entry[:rarity] %>"><%= entry[:rarity].capitalize %></span>
          </div>
          <p class="quest-meta mb-1"><%= entry[:description] %></p>
          <% if entry[:owned] %>
            <p class="quest-meta mb-2">Objectif: <%= entry[:objective] %></p>
          <% else %>
            <p class="quest-meta mb-2">Objectif: secret</p>
          <% end %>

          <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
            <% if entry[:owned] %>
              <span class="shop-state-chip shop-state-chip--owned">Debloque</span>
              <% if entry[:active] %>
                <span class="shop-state-chip shop-state-chip--equipped">Equipe</span>
              <% else %>
                <%= button_to "Equiper", activate_title_path, method: :post, params: { shop_item_id: entry[:id] }, class: "btn btn-sm btn-brand" %>
              <% end %>
            <% else %>
              <span class="shop-state-chip shop-state-chip--available">Bloque</span>
              <span class="quest-meta">Objectif non atteint</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<h2 class="section-title mt-4">Historique des quêtes</h2>
<ul class="list-group surface-list">
  <% @user_quests.each do |user_quest| %>
    <li class="list-group-item">
      <strong><%= user_quest.quest.title %></strong> - Complété <%= user_quest.completed_count %> fois
    </li>
  <% end %>
</ul>
