<h1 class="page-title">Profil de <%= @user.pseudo %></h1>

<!-- Conteneur responsive -->
<div class="row align-items-center">
  <!-- Avatar (colonne gauche) -->
  <div class="col-md-4 text-center">
    <%= user_avatar_image(@user, width: 250, height: 250, css_class: "rounded-circle", alt: "Avatar de #{@user.pseudo}") %>
  </div>

  <!-- Graphique de stats (colonne droite) -->
  <div class="col-md-8">
    <div class="d-flex justify-content-center position-relative">
      <canvas id="statsChart" width="400" height="400"
              data-stats='<%= @stats_data.to_json.html_safe %>'></canvas>
      <div id="totalLevelDisplay" class="position-absolute fw-bold fs-4"
           style="top: 50%; left: 50%; transform: translate(-50%, -50%);">
      </div>
    </div>
  </div>
</div>

<!-- Bouton vers modification de mot de passe -->
<div class="mt-3 text-center">
  <%= link_to "Modifier mon mot de passe", edit_user_registration_path, class: "btn btn-outline-quest" %>
</div>

<!-- Gestion des titres -->
<h2 class="section-title mt-4">Mes Titres</h2>
<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <p class="text-muted small">Titre actuel: <strong class="text-primary"><%= @user.active_title&.name || "Aucun titre actif" %></strong></p>
    
    <% if @owned_titles.any? %>
      <div class="d-flex flex-wrap gap-2">
        <% @owned_titles.each do |title| %>
          <% is_active = @user.active_title_id == title.id %>
          <% rarity_class = title.rarity&.downcase || "common" %>
          <% if is_active %>
            <span class="btn btn-sm btn-brand" style="pointer-events: none; opacity: 1;">
              ✓ <%= title.name %>
            </span>
          <% else %>
            <%= link_to title.name, user_activate_title_path(shop_item_id: title.id), method: :post, class: "btn btn-sm btn-outline-quest" %>
          <% end %>
        <% end %>
        
        <% if @user.active_title.present? %>
          <%= link_to "Retirer le titre", user_deactivate_title_path, method: :post, class: "btn btn-sm btn-outline-secondary" %>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted small">Aucun titre disponible pour le moment. Gagnez-les en boutique!</p>
    <% end %>
  </div>
</div>
<h2 class="section-title mt-4">Historique des quêtes</h2>
<ul class="list-group surface-list">
  <% @user_quests.each do |user_quest| %>
    <li class="list-group-item">
      <strong><%= user_quest.quest.title %></strong> - Complété <%= user_quest.completed_count %> fois
    </li>
  <% end %>
</ul>
