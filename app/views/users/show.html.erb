<h1 class="page-title">Profil de <%= @user.pseudo %></h1>

<div class="row g-3 mb-4">
  <div class="col-md-4"><div class="surface-card"><div class="card-body"><strong>Quetes completees</strong><p class="mb-0"><%= @completed_quests_total %></p></div></div></div>
  <div class="col-md-4"><div class="surface-card"><div class="card-body"><strong>XP cette semaine</strong><p class="mb-0"><%= @xp_this_week %></p></div></div></div>
  <div class="col-md-4"><div class="surface-card"><div class="card-body"><strong>Streak hebdo</strong><p class="mb-0"><%= @user.weekly_streak_count %></p></div></div></div>
</div>

<!-- Conteneur responsive -->
<div class="row align-items-center g-4">
  <!-- Avatar (colonne gauche) -->
  <div class="col-md-4 text-center">
    <%= user_avatar_image(@user, width: 250, height: 250, css_class: "rounded-circle", alt: "Avatar de #{@user.pseudo}") %>
  </div>

  <!-- Actions compte (colonne droite) -->
  <div class="col-md-8">
    <div class="surface-card surface-card--shell">
      <div class="card-body">
        <div class="row g-3 align-items-start">
          <div class="col-lg-8">
            <div class="d-grid gap-2">
              <%= link_to "Modifier mon mot de passe", edit_user_registration_path, class: "btn btn-outline-quest" %>
              <%= form_with url: update_pseudo_path, method: :patch, local: true, class: "d-grid gap-2" do %>
                <%= text_field_tag "user[pseudo]", nil, class: "form-control", placeholder: "Nouveau pseudo", minlength: 3, maxlength: 22 %>
                <%= submit_tag "Changer mon pseudo", class: "btn btn-outline-quest" %>
              <% end %>
            </div>
          </div>
        </div>

        <% if @next_pseudo_change_at.present? %>
          <p class="quest-meta mt-3 mb-0">Prochain changement de pseudo possible le <%= @next_pseudo_change_at.strftime("%d/%m/%Y") %>.</p>
        <% else %>
          <p class="quest-meta mt-3 mb-0">Le pseudo peut etre modifie une fois par semaine.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Gestion des titres -->
<h2 class="section-title mt-4">Cosmétiques</h2>
<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <div class="row g-3">
      <!-- Profile Frame -->
      <div class="col-lg-6">
        <h3 class="section-title">Cadre de Profil</h3>
        <p class="quest-meta mb-2">Encadrement autour de ton pseudo au classement.</p>
        <% frame = @user.active_profile_frame %>
        <% if frame.present? %>
          <div class="shop-state-chip shop-state-chip--equipped mb-2"><%= frame.name %></div>
        <% else %>
          <div class="shop-state-chip shop-state-chip--available mb-2">Aucun cadre actif</div>
        <% end %>
        <div class="shop-list shop-list--flat">
          <% @owned_frames.each do |item| %>
            <div class="shop-row shop-row--flat">
              <strong class="shop-rarity-text shop-rarity-text--<%= item.rarity %>"><%= item.name %></strong>
              <% if frame&.id == item.id %>
                <span class="shop-state-chip shop-state-chip--equipped">Actif</span>
              <% else %>
                <%= button_to item.name, { action: "activate_cosmetic" }, method: :post, params: { shop_item_id: item.id, cosmetic_type: "profile_frame" }, class: "btn btn-sm btn-brand" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- XP Theme -->
      <div class="col-lg-6">
        <h3 class="section-title">Thème de Barre XP</h3>
        <p class="quest-meta mb-2">Couleurs et style de ta barre de progression.</p>
        <% theme = @user.active_xp_theme %>
        <% if theme.present? %>
          <div class="shop-state-chip shop-state-chip--equipped mb-2"><%= theme.name %></div>
        <% else %>
          <div class="shop-state-chip shop-state-chip--available mb-2">Thème par défaut</div>
        <% end %>
        <div class="shop-list shop-list--flat">
          <% @owned_themes.each do |item| %>
            <div class="shop-row shop-row--flat">
              <strong class="shop-rarity-text shop-rarity-text--<%= item.rarity %>"><%= item.name %></strong>
              <% if theme&.id == item.id %>
                <span class="shop-state-chip shop-state-chip--equipped">Actif</span>
              <% else %>
                <%= button_to item.name, { action: "activate_cosmetic" }, method: :post, params: { shop_item_id: item.id, cosmetic_type: "xp_theme" }, class: "btn btn-sm btn-brand" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Profile Card -->
    <div class="mt-4">
      <h3 class="section-title">Carte de Visite</h3>
      <p class="quest-meta mb-2">Affichée dans ton profil et visible par les autres joueurs.</p>
      <% card = @user.active_profile_card %>
      <% if card.present? %>
        <div class="shop-state-chip shop-state-chip--equipped mb-2"><%= card.name %></div>
      <% else %>
        <div class="shop-state-chip shop-state-chip--available mb-2">Aucune carte active</div>
      <% end %>

      <% if card.present? %>
        <%= form_with url: { action: "update_profile_card_text" }, method: :patch, local: true, class: "mb-3" do %>
          <%= text_field_tag "profile_card_text", @user.profile_card_custom_text, class: "form-control", placeholder: "Ton message perso (max 100 caracteres)", maxlength: 100 %>
          <%= submit_tag "Mettre a jour", class: "btn btn-sm btn-brand mt-2" %>
        <% end %>
      <% end %>

      <div class="shop-list shop-list--flat">
        <% @owned_cards.each do |item| %>
          <div class="shop-row shop-row--flat">
            <strong class="shop-rarity-text shop-rarity-text--<%= item.rarity %>"><%= item.name %></strong>
            <% if card&.id == item.id %>
              <span class="shop-state-chip shop-state-chip--equipped">Active</span>
            <% else %>
              <%= button_to item.name, { action: "activate_cosmetic" }, method: :post, params: { shop_item_id: item.id, cosmetic_type: "profile_card" }, class: "btn btn-sm btn-brand" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<h2 class="section-title mt-4">Mes Titres</h2>
<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <p class="mb-2">
      <span class="shop-rarity-text shop-rarity-text--common">Titre actuel:</span>
      <% if @user.active_title.present? %>
        <span class="badge bg-<%= @user.title_rarity_class %>"><%= @user.active_title.name %></span>
      <% else %>
        <strong class="text-white">Aucun titre actif</strong>
      <% end %>
    </p>
    
    <% if @owned_titles.any? %>
      <div class="shop-list shop-list--flat">
        <% @owned_titles.each do |title| %>
          <% is_active = @user.active_title_id == title.id %>
          <% badge_class = case title.rarity
                          when "rare" then "primary"
                          when "epic" then "purple"
                          when "legendary" then "warning"
                          else "secondary"
                          end %>
          <div class="shop-row shop-row--flat d-flex align-items-center justify-content-between gap-2 flex-wrap">
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <span class="badge bg-<%= badge_class %>"><%= title.name %></span>
              <% if is_active %>
                <span class="shop-state-chip shop-state-chip--equipped">Equipe</span>
              <% end %>
            </div>
            <% unless is_active %>
              <%= button_to "Equiper", activate_title_path, method: :post, params: { shop_item_id: title.id }, class: "btn btn-sm btn-brand" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted small">Aucun titre disponible pour le moment. Gagnez-les en boutique!</p>
    <% end %>
  </div>
</div>

<h2 class="section-title mt-4">Titres Communs Gratuits</h2>
<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <div class="shop-list shop-list--flat">
      <% @common_unlockable_titles.each do |entry| %>
        <div class="shop-row shop-row--flat">
          <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
            <strong class="shop-rarity-text shop-rarity-text--common"><%= entry[:name] %></strong>
            <span class="rarity-chip rarity-chip--common">Common</span>
          </div>
          <p class="quest-meta mb-1"><%= entry[:description] %></p>
          <p class="quest-meta mb-2">Objectif: <%= entry[:objective] %></p>

          <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
            <% if entry[:owned] %>
              <span class="shop-state-chip shop-state-chip--owned">Debloque</span>
              <% if entry[:active] %>
                <span class="shop-state-chip shop-state-chip--equipped">Equipe</span>
              <% else %>
                <%= button_to "Equiper", activate_title_path, method: :post, params: { shop_item_id: entry[:id] }, class: "btn btn-sm btn-brand" %>
              <% end %>
            <% else %>
              <span class="shop-state-chip shop-state-chip--available">Bloque</span>
              <span class="quest-meta">Objectif non atteint</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<h2 class="section-title mt-4">Titres Prestige Gratuits</h2>
<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <div class="shop-list shop-list--flat">
      <% @prestige_unlockable_titles.each do |entry| %>
        <div class="shop-row shop-row--flat">
          <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
            <strong class="shop-rarity-text shop-rarity-text--<%= entry[:rarity] %>"><%= entry[:name] %></strong>
            <span class="rarity-chip rarity-chip--<%= entry[:rarity] %>"><%= entry[:rarity].capitalize %></span>
          </div>
          <p class="quest-meta mb-1"><%= entry[:description] %></p>
          <% if entry[:owned] %>
            <p class="quest-meta mb-2">Objectif: <%= entry[:objective] %></p>
          <% else %>
            <p class="quest-meta mb-2">Objectif: secret</p>
          <% end %>

          <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
            <% if entry[:owned] %>
              <span class="shop-state-chip shop-state-chip--owned">Debloque</span>
              <% if entry[:active] %>
                <span class="shop-state-chip shop-state-chip--equipped">Equipe</span>
              <% else %>
                <%= button_to "Equiper", activate_title_path, method: :post, params: { shop_item_id: entry[:id] }, class: "btn btn-sm btn-brand" %>
              <% end %>
            <% else %>
              <span class="shop-state-chip shop-state-chip--available">Bloque</span>
              <span class="quest-meta">Objectif non atteint</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<h2 class="section-title mt-4">Historique des quêtes</h2>
<ul class="list-group surface-list">
  <% @user_quests.each do |user_quest| %>
    <li class="list-group-item">
      <strong><%= user_quest.quest.title %></strong> - Complété <%= user_quest.completed_count %> fois
    </li>
  <% end %>
</ul>

<h2 class="section-title mt-4">Historique des defis amis</h2>
<ul class="list-group surface-list">
  <% if @challenge_history.any? %>
    <% @challenge_history.each do |challenge| %>
      <% opponent = challenge.challenger == @user ? challenge.challenged : challenge.challenger %>
      <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span>Contre <strong><%= opponent.pseudo %></strong></span>
        <% if challenge.winner_id == @user.id %>
          <span class="badge text-bg-success">Victoire (+<%= challenge.reward_coins %> Fragments)</span>
        <% elsif challenge.winner_id.present? %>
          <span class="badge text-bg-secondary">Defaite</span>
        <% else %>
          <span class="badge text-bg-warning">Egalite</span>
        <% end %>
      </li>
    <% end %>
  <% else %>
    <li class="list-group-item">Aucun defi termine pour le moment.</li>
  <% end %>
</ul>
