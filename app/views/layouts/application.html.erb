<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <title><%= page_meta_title %></title>
  <meta name="description" content="<%= page_meta_description %>">
  <meta name="robots" content="<%= page_robots_content %>">
  <% if page_canonical_url.present? %>
    <link rel="canonical" href="<%= page_canonical_url %>">
  <% end %>
  <% page_alternate_locale_urls.each do |locale_code, href| %>
    <link rel="alternate" hreflang="<%= locale_code %>" href="<%= href %>">
  <% end %>
  <% if page_x_default_url.present? %>
    <link rel="alternate" hreflang="x-default" href="<%= page_x_default_url %>">
  <% end %>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="MotivUp">
  <meta property="og:title" content="<%= page_meta_title %>">
  <meta property="og:description" content="<%= page_meta_description %>">
  <meta property="og:locale" content="<%= page_og_locale %>">
  <% page_alternate_locale_urls.each_key do |locale_code| %>
    <% next if locale_code == I18n.locale.to_s %>
    <meta property="og:locale:alternate" content="<%= locale_code == 'fr' ? 'fr_FR' : locale_code %>">
  <% end %>
  <% if page_canonical_url.present? %>
    <meta property="og:url" content="<%= page_canonical_url %>">
  <% end %>
  <meta property="og:image" content="<%= page_og_image_url %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= page_meta_title %>">
  <meta name="twitter:description" content="<%= page_meta_description %>">
  <meta name="twitter:image" content="<%= page_og_image_url %>">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= favicon_link_tag "logo-motivup.svg", type: "image/svg+xml" %>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", media: "all" %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.js"></script>

  <%= javascript_importmap_tags %>
</head>
<body>
  <div class="app-shell">
  <nav class="navbar navbar-expand-lg navbar-dark topbar-motivup">
    <div class="container py-1">
      <a class="navbar-brand d-inline-flex align-items-center" href="<%= root_path %>">
        <%= image_tag "logo-motivup.svg", width: 18, height: 18, alt: t("layout.brand_logo_alt"), class: "me-2" %>
        <span>MotivUp</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav gap-1">
          <li class="nav-item">
            <%= link_to t("layout.nav.home"), root_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to t("layout.nav.quests"), quests_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to t("layout.nav.shop"), new_purchase_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to t("layout.nav.leaderboard"), leaderboard_index_path, class: "nav-link" if user_signed_in? %>
          </li>
          <li class="nav-item">
            <%= link_to t("layout.nav.friends"), friends_path, class: "nav-link" if user_signed_in? %>
          </li>
        </ul>
        <ul class="navbar-nav ms-auto gap-1 align-items-lg-center">
          <% if user_signed_in? %>
            <% if current_user.admin? %>
              <li class="nav-item">
                <%= link_to "Admin", admin_quests_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Analytics", admin_analytics_path, class: "nav-link" %>
              </li>
            <% end %>
            <li class="nav-item">
              <%= link_to notifications_path, class: "nav-link" do %>
                <%= t("layout.nav.notifications") %>
                <% if @unread_notifications_count.to_i.positive? %>
                  <span class="badge text-bg-warning ms-1"><%= @unread_notifications_count %></span>
                <% end %>
              <% end %>
            </li>
            <li class="nav-item">
              <%= link_to t("layout.nav.profile"), user_profile_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= form_with url: destroy_user_session_path, method: :delete, local: true do %>
                <%= submit_tag t("layout.nav.sign_out"), class: "btn btn-link nav-link p-0" %>
              <% end %>
            </li>
          <% else %>
            <li class="nav-item">
              <%= link_to t("layout.nav.sign_in"), new_user_session_path, class: "nav-link" %>
            </li>
          <% end %>
          <li class="nav-item">
            <%= link_to t("layout.nav.report_bug"), "https://github.com/Kilanga/motivup-app/issues/new", class: "nav-link", target: "_blank", rel: "noopener" %>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container mt-4 page-content">
    <%= render 'layouts/flash' %>
    <%= yield %>
  </main>
  <footer class="footer-global" style="background: linear-gradient(120deg, #0a1623, #0f2233); border-top: 1px solid rgba(86,202,248,0.12); color: #b8d8ec; padding: 0.7rem 0 0.4rem 0; text-align: center; font-size: 0.97em; opacity: 0.82;">
    <div>
      <a href="<%= terms_path %>" style="color: #7ddcff; text-decoration: underline; font-weight: 400; opacity: 0.85;"> <%= t('pages.terms.title', default: "Conditions d'Utilisation") %></a>
      <span style="color: #2ab8f2; font-weight: 400; opacity: 0.5;"> | </span>
      <a href="<%= privacy_path %>" style="color: #7ddcff; text-decoration: underline; font-weight: 400; opacity: 0.85;"> <%= t('pages.privacy.title', default: "Politique de Confidentialité") %></a>
    </div>
    <div style="margin-top: 0.3rem; color: #b8d8ec; opacity: 0.65;">
      &copy; <%= Time.current.year %> MotivUp
    </div>
  </footer>
  </div>
</body>
</html>
