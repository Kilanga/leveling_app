<h1 class="page-title">Marche des aventuriers</h1>
<p class="page-subtitle">Obtenez des ressources premium pour accelerer votre progression.</p>
<p class="quest-meta mb-3">Tes coins: <strong><%= current_user.coins %></strong></p>

<div class="surface-card surface-card--shell">
  <div class="card-body">
    <section class="hud-section mb-3">
      <div class="shop-tab-nav">
        <%= link_to "Packs", new_purchase_path(tab: "packs"), class: "shop-tab #{'shop-tab--active' if @active_shop_tab == 'packs'}" %>
        <%= link_to "Boosts", new_purchase_path(tab: "boosts"), class: "shop-tab #{'shop-tab--active' if @active_shop_tab == 'boosts'}" %>
        <%= link_to "Cosmetiques", new_purchase_path(tab: "cosmetics"), class: "shop-tab #{'shop-tab--active' if @active_shop_tab == 'cosmetics'}" %>
      </div>
    </section>

    <div class="row g-4">
      <div class="col-lg-8">
        <section class="hud-section h-100">
          <% if @active_shop_tab == "packs" %>
            <h2 class="section-title">Packs de coins</h2>
            <div class="shop-list shop-list--flat shop-list--boosts">
              <% @coins_prices.each do |option| %>
                <% value_per_euro = (option[:coins].to_f / option[:amount]).round(1) %>
                <div class="shop-row shop-row--flat">
                  <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid gap-2" do %>
                    <%= hidden_field_tag :amount, option[:amount] %>
                    <%= hidden_field_tag :item_type, option[:label] %>
                    <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                      <strong><%= option[:label] %></strong>
                      <% if option[:label] == @best_value_pack_label %>
                        <span class="shop-state-chip shop-state-chip--best">Best value</span>
                      <% end %>
                    </div>
                    <p class="quest-meta mb-1"><%= option[:description] %></p>
                    <p class="quest-meta mb-1"><%= value_per_euro %> coins / EUR</p>
                    <%= submit_tag "Acheter - #{option[:amount]} EUR", class: "btn btn-brand" %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% elsif @active_shop_tab == "boosts" %>
            <h2 class="section-title">Boosts XP</h2>
            <div class="shop-list shop-list--flat">
              <% @boosts.each do |boost| %>
                <div class="shop-row shop-row--flat">
                  <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid gap-2" do %>
                    <%= hidden_field_tag :amount, boost[:amount] %>
                    <%= hidden_field_tag :item_type, boost[:label] %>
                    <strong><%= boost[:label] %></strong>
                    <p class="quest-meta mb-1"><%= boost[:description] %></p>
                    <p class="quest-meta mb-1">Progression accéléree pendant <%= distance_of_time_in_words(boost[:duration]) %>.</p>
                    <%= submit_tag "Activer - #{boost[:amount]} EUR", class: "btn btn-brand" %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <h2 class="section-title">Titres</h2>
            <p class="quest-meta mb-3">Choisis un titre marquant pour imposer ton style dans le classement.</p>

            <% if current_user.active_title.present? %>
              <div class="shop-row shop-row--flat mb-3">
                <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                  <strong>Equipe maintenant</strong>
                  <div class="d-flex gap-2 flex-wrap">
                    <span class="shop-state-chip shop-state-chip--equipped">Titre: <%= current_user.active_title.name %></span>
                  </div>
                </div>
              </div>
            <% end %>

            <div class="shop-list shop-list--flat shop-list--titles">
              <% @title_items.each do |item| %>
                <% rarity_key = item.rarity.to_s.presence || "common" %>
                <% rarity_label = item.rarity.to_s.capitalize.presence || "Common" %>
                <% rarity_css = "rarity-chip rarity-chip--#{rarity_key}" %>
                <% owned = @owned_item_ids.include?(item.id) %>
                <% equipped = current_user.active_title_id == item.id %>
                <div class="shop-row shop-row--flat">
                  <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                    <strong class="shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= item.name %></strong>
                    <span class="<%= rarity_css %>"><%= rarity_label %></span>
                  </div>
                  <p class="quest-meta mb-2"><%= @item_personalized_descriptions[item.id] %></p>

                  <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
                    <span class="shop-state-chip <%= equipped ? 'shop-state-chip--equipped' : owned ? 'shop-state-chip--owned' : 'shop-state-chip--available' %>">
                      <%= equipped ? "Equipe" : owned ? "Possede" : "Disponible" %>
                    </span>
                    <% if item.price_coins.present? %>
                      <span class="quest-meta shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= item.price_coins %> coins</span>
                    <% elsif item.price_euros.present? %>
                      <span class="quest-meta shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= item.price_euros %> EUR</span>
                    <% end %>
                  </div>

                  <% if equipped %>
                    <%= button_to "Retirer", deactivate_title_path, method: :post, class: "btn btn-sm btn-outline-secondary" %>
                  <% elsif owned %>
                    <%= button_to "Equiper", activate_title_path, method: :post, params: { shop_item_id: item.id }, class: "btn btn-sm btn-brand" %>
                  <% elsif item.price_coins.present? || item.price_euros.present? %>
                    <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                      <%= hidden_field_tag :shop_item_id, item.id %>
                      <%= submit_tag "Acheter", class: "btn btn-outline-quest" %>
                    <% end %>
                  <% else %>
                    <span class="badge text-bg-secondary">Indisponible</span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </section>
      </div>

      <div class="col-lg-4">
        <section class="hud-section h-100">
          <h2 class="section-title">Apercu profil</h2>
          <div class="shop-preview-card mb-4">
            <div class="d-flex align-items-center gap-3">
              <%= user_avatar_image(current_user, width: 74, height: 74, css_class: "rounded-circle shop-preview-avatar", alt: "Avatar de #{current_user.pseudo}") %>
              <div>
                <strong><%= current_user.pseudo %></strong>
                <p class="quest-meta mb-1">Niveau global <%= @total_level %></p>
                <% if current_user.active_title.present? %>
                  <p class="quest-meta mb-0">Titre: <%= current_user.active_title.name %></p>
                <% else %>
                  <p class="quest-meta mb-0">Aucun titre equipe</p>
                <% end %>
              </div>
            </div>
          </div>

          <h2 class="section-title">Recommande pour toi</h2>
          <% if @recommended_shop_items.any? %>
            <div class="shop-reco-list">
              <% @recommended_shop_items.each do |item| %>
                <% rarity_key = item.rarity.to_s.presence || "common" %>
                <% rarity_label = item.rarity.to_s.capitalize.presence || "Common" %>
                <div class="shop-row shop-row--flat">
                  <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap mb-2">
                    <strong class="shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= item.name %></strong>
                    <span class="rarity-chip rarity-chip--<%= rarity_key %>"><%= rarity_label %></span>
                  </div>
                  <p class="quest-meta mb-2"><%= @item_personalized_descriptions[item.id] %></p>
                  <% if item.price_coins.present? %>
                    <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                      <%= hidden_field_tag :shop_item_id, item.id %>
                      <%= submit_tag "Acheter #{item.price_coins} coins", class: "btn btn-sm btn-outline-quest" %>
                    <% end %>
                  <% elsif item.price_euros.present? %>
                    <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                      <%= hidden_field_tag :shop_item_id, item.id %>
                      <%= submit_tag "Acheter #{item.price_euros} EUR", class: "btn btn-sm btn-outline-quest" %>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="alert alert-warning mb-0">Tu possedes deja les meilleurs objets disponibles.</div>
          <% end %>

          <hr class="hud-divider">

          <h2 class="section-title">Defi boutique hebdo</h2>
          <p class="quest-meta mb-2">Complete les 3 objectifs et recupere <%= PurchasesController::SHOP_CHALLENGE_REWARD_COINS %> coins.</p>
          <div class="shop-challenge-card mb-3">
            <% @shop_challenge.fetch(:steps, []).each do |step| %>
              <div class="shop-challenge-step">
                <span class="shop-state-chip <%= step[:completed] ? 'shop-state-chip--equipped' : 'shop-state-chip--available' %>">
                  <%= step[:completed] ? 'OK' : 'A faire' %>
                </span>
                <span><%= step[:label] %></span>
              </div>
            <% end %>
          </div>

          <% if @shop_challenge_claimed %>
            <span class="shop-state-chip shop-state-chip--owned">Recompense deja recuperee cette semaine</span>
          <% elsif @shop_challenge[:completed_all] %>
            <%= button_to "Recuperer la recompense", claim_weekly_challenge_purchases_path, method: :post, class: "btn btn-brand" %>
          <% else %>
            <span class="shop-state-chip shop-state-chip--available"><%= @shop_challenge.fetch(:completed_count, 0) %>/<%= @shop_challenge.fetch(:total_count, 0) %> objectifs completes</span>
          <% end %>
        </section>
      </div>
    </div>
  </div>
</div>

<div class="mt-4">
  <%= link_to "Retour au tableau de bord", root_path, class: "btn btn-outline-secondary" %>
</div>
