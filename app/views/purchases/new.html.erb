<h1 class="page-title">Marche des aventuriers</h1>
<p class="page-subtitle">Obtenez des ressources premium pour accelerer votre progression.</p>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="surface-card h-100">
      <div class="card-body">
        <h2 class="section-title">Packs de coins</h2>
        <div class="shop-list">
          <% @coins_prices.each do |option| %>
            <div class="shop-row">
              <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid gap-2" do %>
                <%= hidden_field_tag :amount, option[:amount] %>
                <%= hidden_field_tag :item_type, option[:label] %>
                <strong><%= option[:label] %></strong>
                <%= submit_tag "Acheter - #{option[:amount]} EUR", class: "btn btn-brand" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="surface-card h-100">
      <div class="card-body">
        <h2 class="section-title">Boosts XP</h2>
        <div class="shop-list">
          <% @boosts.each do |boost| %>
            <div class="shop-row">
              <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid gap-2" do %>
                <%= hidden_field_tag :amount, boost[:amount] %>
                <%= hidden_field_tag :item_type, boost[:label] %>
                <strong><%= boost[:label] %></strong>
                <%= submit_tag "Activer - #{boost[:amount]} EUR", class: "btn btn-success" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="surface-card h-100">
      <div class="card-body">
        <h2 class="section-title">Titres et avatars</h2>
        <p class="quest-meta mb-3">Objets de prestige visibles par les autres joueurs sur profil et classement.</p>

        <% if @bundles.any? %>
          <div class="shop-list mb-3">
            <h3 class="h6 mb-1">Bundles recommandes</h3>
            <% @bundles.each do |bundle| %>
              <% rarity_css = "rarity-chip rarity-chip--#{bundle[:rarity]}" %>
              <% owned_any = @owned_item_ids.include?(bundle[:title_item].id) || @owned_item_ids.include?(bundle[:avatar_item].id) %>
              <div class="shop-row bundle-card">
                <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                  <strong>Pack <%= bundle[:rarity].capitalize %>:</strong>
                  <span class="<%= rarity_css %>"><%= bundle[:rarity].capitalize %></span>
                </div>
                <p class="quest-meta mb-1"><strong><%= bundle[:title_item].name %></strong> + <strong><%= bundle[:avatar_item].name %></strong></p>
                <p class="quest-meta mb-2">Prix normal: <%= bundle[:base_price] %> coins. Prix bundle: <strong><%= bundle[:bundle_price] %> coins</strong> (economie <%= bundle[:savings] %>).</p>

                <% if owned_any %>
                  <span class="badge text-bg-secondary">Bundle deja partiellement possede</span>
                <% else %>
                  <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                    <%= hidden_field_tag :bundle_title_id, bundle[:title_item].id %>
                    <%= hidden_field_tag :bundle_avatar_id, bundle[:avatar_item].id %>
                    <%= submit_tag "Acheter le bundle", class: "btn btn-brand" %>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if current_user.active_title.present? %>
          <div class="shop-row mb-3">
            <span class="badge text-bg-dark mb-2">Titre actif</span>
            <div class="d-flex align-items-center justify-content-between gap-2">
              <strong><%= current_user.active_title.name %></strong>
              <%= button_to "Retirer", deactivate_title_path, method: :post, class: "btn btn-sm btn-outline-secondary" %>
            </div>
          </div>
        <% end %>

        <% if current_user.active_avatar_item.present? %>
          <div class="shop-row mb-3">
            <span class="badge text-bg-dark mb-2">Avatar actif</span>
            <div class="d-flex align-items-center gap-2">
              <%= image_tag current_user.active_avatar_item.image.variant(resize: "48x48"), class: "rounded shop-thumb", width: 48, height: 48 if current_user.active_avatar_item.image.attached? %>
              <strong><%= current_user.active_avatar_item.name %></strong>
            </div>
          </div>
        <% end %>

        <div class="shop-list mb-3">
          <h3 class="h6 mb-1">Titres</h3>
          <% @title_items.each do |item| %>
            <% rarity_css = "rarity-chip rarity-chip--#{item.rarity}" %>
            <% owned = @owned_item_ids.include?(item.id) %>
            <div class="shop-row">
              <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                <strong><%= item.name %></strong>
                <span class="<%= rarity_css %>"><%= item.rarity.capitalize %></span>
              </div>
              <p class="quest-meta mb-2"><%= item.description %> Affiche ce titre sur votre profil.</p>
              <% if owned && current_user.active_title_id == item.id %>
                <span class="badge text-bg-primary">Equipe</span>
              <% elsif owned %>
                <div class="d-grid gap-2">
                  <span class="badge text-bg-success">Deja possede</span>
                  <%= button_to "Equiper", activate_title_path, method: :post, params: { shop_item_id: item.id }, class: "btn btn-sm btn-brand" %>
                </div>
              <% elsif item.price_coins.present? %>
                <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                  <%= hidden_field_tag :shop_item_id, item.id %>
                  <%= submit_tag "Acheter pour #{item.price_coins} coins", class: "btn btn-outline-quest" %>
                <% end %>
              <% else %>
                <span class="badge text-bg-secondary">Indisponible</span>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="shop-list">
          <h3 class="h6 mb-1">Avatars</h3>
          <% @avatar_items.each do |item| %>
            <% rarity_css = "rarity-chip rarity-chip--#{item.rarity}" %>
            <% owned = @owned_item_ids.include?(item.id) %>
            <div class="shop-row">
              <div class="d-flex align-items-center gap-2 mb-2">
                <% if item.image.attached? %>
                  <%= image_tag item.image.variant(resize: "64x64"), class: "rounded shop-thumb" %>
                <% end %>
                <div class="flex-grow-1">
                  <div class="d-flex align-items-start justify-content-between gap-2">
                    <strong><%= item.name %></strong>
                    <span class="<%= rarity_css %>"><%= item.rarity.capitalize %></span>
                  </div>
                  <p class="quest-meta mb-0"><%= item.description %></p>
                </div>
              </div>
              <% if owned && current_user.active_avatar_item_id == item.id %>
                <span class="badge text-bg-primary">Equipe</span>
              <% elsif owned %>
                <div class="d-grid gap-2">
                  <span class="badge text-bg-success">Deja possede</span>
                  <%= button_to "Equiper", activate_avatar_path, method: :post, params: { shop_item_id: item.id }, class: "btn btn-sm btn-brand" %>
                </div>
              <% elsif item.price_coins.present? %>
                <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                  <%= hidden_field_tag :shop_item_id, item.id %>
                  <%= submit_tag "Acheter pour #{item.price_coins} coins", class: "btn btn-outline-quest" %>
                <% end %>
              <% else %>
                <span class="badge text-bg-secondary">Indisponible</span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="mt-4">
  <%= link_to "Retour au tableau de bord", root_path, class: "btn btn-outline-secondary" %>
</div>
