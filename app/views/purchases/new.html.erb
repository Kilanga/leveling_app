<h1 class="page-title"><%= t('purchases.new.page_title') %></h1>
<p class="page-subtitle"><%= t('purchases.new.page_subtitle') %></p>
<p class="quest-meta mb-1">Tes <strong>Orbes</strong> premium: <strong><%= current_user.coins %></strong></p>
<p class="quest-meta mb-3">Tes <strong>Fragments</strong> de progression: <strong><%= current_user.free_credits_balance %></strong></p>
<% if @entry_offer_enabled %>
  <div class="surface-card mb-4 welcome-offer-card">
    <div class="card-body d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div class="welcome-offer-copy">
        <p class="welcome-offer-kicker mb-1"><%= t('purchases.new.welcome_offer_kicker') %></p>
        <h2 class="section-title mb-2"><%= t('purchases.new.welcome_bonus_heading', percentage: (@entry_offer_bonus_rate * 100).to_i) %></h2>
        <p class="quest-meta mb-0"><%= t('purchases.new.welcome_bonus_help') %></p>
      </div>
      <span class="shop-state-chip shop-state-chip--best"><%= t('purchases.new.first_purchase_badge') %></span>
    </div>
  </div>
<% end %>

<div class="surface-card surface-card--shell">
  <div class="card-body">
    <% if @daily_deals.any? %>
      <section class="hud-section mb-3 daily-deals">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
          <h2 class="section-title mb-0">⚡ <%= t('purchases.new.deals.heading') %></h2>
          <span class="shop-state-chip shop-state-chip--best js-deal-countdown" data-deadline="<%= Time.zone.now.end_of_day.iso8601 %>"><%= t('purchases.new.deals.ends_at_midnight') %></span>
        </div>
        <div class="row g-3">
          <% @daily_deals.each do |deal| %>
            <% item = deal[:item] %>
            <% owned = @owned_item_ids.include?(item.id) %>
            <div class="col-md-4">
              <div class="shop-row shop-row--flat daily-deal-card daily-deal-card--<%= item.rarity %>">
                <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
                  <strong class="shop-rarity-text shop-rarity-text--<%= item.rarity %>"><%= item.name %></strong>
                  <span class="shop-state-chip shop-state-chip--best">-<%= (DailyShopDeals::DISCOUNT_RATE * 100).round %>%</span>
                </div>
                <p class="quest-meta mb-2"><%= item.description %></p>

                <div class="shop-cosmetic-preview shop-cosmetic-preview--<%= item.rarity %> mb-2">
                  <div class="preview-label"><%= t('purchases.new.cosmetics.preview_label') %></div>
                  <% case item.item_type %>
                  <% when "profile_frame" %>
                    <div class="profile-frame-container <%= frame_wrapper_classes(item) %>"><%= current_user.pseudo %></div>
                  <% when "xp_theme" %>
                    <div class="xp-track <%= xp_theme_classes(item) %>"><div class="xp-fill" style="width: 65%"></div></div>
                  <% when "profile_card" %>
                    <div class="profile-card-container <%= profile_card_classes(item) %>">
                      <div class="profile-card-header"><%= current_user.pseudo %></div>
                      <div class="profile-card-text"><%= t('purchases.new.cosmetics.card_preview_hint') %></div>
                    </div>
                  <% else %>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                      <strong><%= current_user.pseudo %></strong>
                      <span class="shop-state-chip shop-state-chip--available shop-rarity-text--<%= item.rarity %>"><%= item.name %></span>
                    </div>
                  <% end %>
                </div>
                <p class="quest-meta mb-2">
                  <s class="muted-label"><%= t('purchases.new.prices.orbs', count: deal[:original_price]) %></s>
                  <strong class="ms-1"><%= t('purchases.new.prices.orbs', count: deal[:deal_price]) %></strong>
                </p>
                <% if owned %>
                  <span class="shop-state-chip shop-state-chip--owned"><%= t('purchases.new.cosmetics.status_owned') %></span>
                <% else %>
                  <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                    <%= hidden_field_tag :shop_item_id, item.id %>
                    <%= submit_tag t('purchases.new.deals.buy_button'), class: "btn btn-brand" %>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <section class="hud-section mb-3">
      <div class="shop-tab-nav">
        <%= link_to t('purchases.new.tabs.cosmetics'), new_purchase_path(tab: "cosmetics"), class: "shop-tab #{'shop-tab--active' if @active_shop_tab == 'cosmetics'}" %>
        <%= link_to t('purchases.new.tabs.boosts'), new_purchase_path(tab: "boosts"), class: "shop-tab #{'shop-tab--active' if @active_shop_tab == 'boosts'}" %>
        <%= link_to t('purchases.new.tabs.titles'), new_purchase_path(tab: "titles"), class: "shop-tab #{'shop-tab--active' if @active_shop_tab == 'titles'}" %>
        <%= link_to t('purchases.new.tabs.rewards'), new_purchase_path(tab: "rewards"), class: "shop-tab #{'shop-tab--active' if @active_shop_tab == 'rewards'}" %>
        <%= link_to t('season_pass.page_title'), season_pass_path, class: "shop-tab" %>
      </div>
    </section>

    <div class="row g-4">
      <div class="col-lg-8">
        <section class="hud-section h-100">
          <% if @active_shop_tab == "boosts" %>
            <h2 class="section-title"><%= t('purchases.new.boosts.heading') %></h2>
            <div class="shop-list shop-list--flat">
              <% @boosts.each do |boost| %>
                <div class="shop-row shop-row--flat">
                  <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid gap-2" do %>
                    <%= hidden_field_tag :amount, boost[:amount] %>
                    <%= hidden_field_tag :item_type, boost[:label] %>
                    <strong><%= boost[:label] %></strong>
                    <p class="quest-meta mb-1"><%= boost[:description] %></p>
                    <p class="quest-meta mb-1"><%= t('purchases.new.boosts.description', duration: distance_of_time_in_words(boost[:duration])) %></p>
                    <%= submit_tag t('purchases.new.boosts.activate_button', price: boost[:amount]), class: "btn btn-brand" %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% elsif @active_shop_tab == "titles" %>
            <h2 class="section-title"><%= t('purchases.new.titles.heading') %></h2>
            <p class="quest-meta mb-3"><%= t('purchases.new.titles.instruction') %></p>

            <% if current_user.active_title.present? %>
              <div class="shop-row shop-row--flat mb-3">
                <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                  <strong><%= t('purchases.new.titles.equipped_text') %></strong>
                  <div class="d-flex gap-2 flex-wrap">
                    <span class="shop-state-chip shop-state-chip--equipped"><%= t('purchases.new.titles.equipped_badge') %>: <%= current_user.active_title.name %></span>
                  </div>
                </div>
              </div>
            <% end %>

            <div class="shop-list shop-list--flat shop-list--titles">
              <% @title_items.each do |item| %>
                <% rarity_key = item.rarity.to_s.presence || "common" %>
                <% rarity_label = item.rarity.to_s.capitalize.presence || "Common" %>
                <% rarity_css = "rarity-chip rarity-chip--#{rarity_key}" %>
                <% owned = @owned_item_ids.include?(item.id) %>
                <% equipped = current_user.active_title_id == item.id %>
                <div class="shop-row shop-row--flat">
                  <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                    <strong class="shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= item.name %></strong>
                    <span class="<%= rarity_css %>"><%= rarity_label %></span>
                  </div>
                  <p class="quest-meta mb-2"><%= @item_personalized_descriptions[item.id] %></p>

                  <!-- Aperçu du titre -->
                  <div class="shop-cosmetic-preview shop-cosmetic-preview--<%= rarity_key %> mb-2">
                    <div class="preview-label"><%= t('purchases.new.cosmetics.preview_label') %></div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                      <strong><%= current_user.pseudo %></strong>
                      <span class="shop-state-chip shop-state-chip--available shop-rarity-text--<%= rarity_key %>"><%= item.name %></span>
                    </div>
                  </div>

                  <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
                    <span class="shop-state-chip <%= equipped ? 'shop-state-chip--equipped' : owned ? 'shop-state-chip--owned' : 'shop-state-chip--available' %>">
                      <%= equipped ? t('purchases.new.titles.equipped_badge') : owned ? t('purchases.new.titles.owned_badge') : t('purchases.new.titles.available_badge') %>
                    </span>
                    <% if item.price_coins.present? %>
                      <span class="quest-meta shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= t('purchases.new.prices.orbs', count: item.price_coins) %></span>
                    <% elsif item.price_free_credits.present? %>
                      <span class="quest-meta shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= t('purchases.new.prices.fragments', count: item.price_free_credits) %></span>
                    <% elsif item.price_euros.present? %>
                      <span class="quest-meta shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= t('purchases.new.prices.euros', count: item.price_euros) %></span>
                    <% end %>
                  </div>

                  <% if equipped %>
                    <%= button_to t('purchases.new.titles.remove_button'), deactivate_title_path, method: :post, class: "btn btn-sm btn-outline-secondary" %>
                  <% elsif owned %>
                    <%= button_to t('purchases.new.titles.equip_button'), activate_title_path, method: :post, params: { shop_item_id: item.id }, class: "btn btn-sm btn-brand" %>
                  <% elsif item.price_coins.present? || item.price_free_credits.present? || item.price_euros.present? %>
                    <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                      <%= hidden_field_tag :shop_item_id, item.id %>
                      <%= submit_tag t('purchases.new.titles.buy_button'), class: "btn btn-outline-quest" %>
                    <% end %>
                  <% else %>
                    <span class="badge text-bg-secondary"><%= t('purchases.new.titles.unavailable_badge') %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% elsif @active_shop_tab == "cosmetics" %>
            <% cosmetics_activation_supported = current_user.respond_to?(:active_profile_frame_id) && current_user.respond_to?(:active_xp_theme_id) && current_user.respond_to?(:active_profile_card_id) %>
            <% active_profile_frame_id = cosmetics_activation_supported ? current_user.active_profile_frame_id : nil %>
            <% active_xp_theme_id = cosmetics_activation_supported ? current_user.active_xp_theme_id : nil %>
            <% active_profile_card_id = cosmetics_activation_supported ? current_user.active_profile_card_id : nil %>

            <h2 class="section-title"><%= t('purchases.new.cosmetics.heading') %></h2>
            <p class="quest-meta mb-3"><%= t('purchases.new.cosmetics.instruction') %></p>
            <% unless cosmetics_activation_supported %>
              <div class="alert alert-warning">
                <%= t('purchases.new.cosmetics.activation_pending') %>
              </div>
            <% end %>

            <!-- Cadres de Profil -->
            <h3 class="section-title mt-4"><%= t('purchases.new.cosmetics.profile_frames_heading') %></h3>
            <div class="shop-list shop-list--flat">
              <% @frame_items.each do |item| %>
                <% rarity_key = item.rarity.to_s.presence || "common" %>
                <% owned = @owned_item_ids.include?(item.id) %>
                <% active = cosmetics_activation_supported && active_profile_frame_id == item.id %>
                <div class="shop-row shop-row--flat">
                  <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                    <strong class="shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= item.name %></strong>
                    <span class="rarity-chip rarity-chip--<%= rarity_key %>"><%= item.rarity.to_s.capitalize %></span>
                  </div>
                  <p class="quest-meta mb-2"><%= @item_personalized_descriptions[item.id] %></p>

                  <!-- Aperçu du cadre -->
                  <div class="shop-cosmetic-preview shop-cosmetic-preview--<%= rarity_key %> mb-2">
                    <div class="preview-label"><%= t('purchases.new.cosmetics.preview_label') %></div>
                    <div class="profile-frame-container <%= frame_wrapper_classes(item) %>">
                      <%= current_user.pseudo %>
                    </div>
                  </div>

                  <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
                    <span class="shop-state-chip <%= active ? 'shop-state-chip--equipped' : owned ? 'shop-state-chip--owned' : 'shop-state-chip--available' %>">
                      <%= active ? t('purchases.new.cosmetics.status_active') : owned ? t('purchases.new.cosmetics.status_owned') : t('purchases.new.cosmetics.status_available') %>
                    </span>
                    <% if item.price_coins.present? %>
                      <span class="quest-meta"><%= t('purchases.new.prices.orbs', count: item.price_coins) %></span>
                    <% elsif item.price_free_credits.present? %>
                      <span class="quest-meta"><%= t('purchases.new.prices.fragments', count: item.price_free_credits) %></span>
                    <% elsif item.price_euros.present? %>
                      <span class="quest-meta"><%= t('purchases.new.prices.euros', count: item.price_euros) %></span>
                    <% end %>
                  </div>

                  <% if !cosmetics_activation_supported %>
                    <span class="badge text-bg-secondary"><%= t('purchases.new.cosmetics.activation_unavailable') %></span>
                  <% elsif active %>
                    <%= button_to "Desactiver", activate_cosmetic_path, method: :post, params: { shop_item_id: nil, cosmetic_type: "profile_frame" }, class: "btn btn-sm btn-outline-secondary" %>
                  <% elsif owned %>
                    <%= button_to "Activer", activate_cosmetic_path, method: :post, params: { shop_item_id: item.id, cosmetic_type: "profile_frame" }, class: "btn btn-sm btn-brand" %>
                  <% elsif item.price_coins.present? || item.price_free_credits.present? || item.price_euros.present? %>
                    <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                      <%= hidden_field_tag :shop_item_id, item.id %>
                      <%= submit_tag t('purchases.new.cosmetics.buy_button'), class: "btn btn-outline-quest" %>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>

            <!-- Themes XP -->
            <h3 class="section-title mt-4"><%= t('purchases.new.cosmetics.xp_themes_heading') %></h3>
            <div class="shop-list shop-list--flat">
              <% @theme_items.each do |item| %>
                <% rarity_key = item.rarity.to_s.presence || "common" %>
                <% owned = @owned_item_ids.include?(item.id) %>
                <% active = cosmetics_activation_supported && active_xp_theme_id == item.id %>
                <div class="shop-row shop-row--flat">
                  <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                    <strong class="shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= item.name %></strong>
                    <span class="rarity-chip rarity-chip--<%= rarity_key %>"><%= item.rarity.to_s.capitalize %></span>
                  </div>
                  <p class="quest-meta mb-2"><%= @item_personalized_descriptions[item.id] %></p>

                  <!-- Aperçu du thème XP -->
                  <div class="shop-cosmetic-preview shop-cosmetic-preview--<%= rarity_key %> mb-2">
                    <div class="preview-label"><%= t('purchases.new.cosmetics.preview_label') %></div>
                    <div class="xp-track <%= xp_theme_classes(item) %>">
                      <div class="xp-fill" style="width: 65%"></div>
                    </div>
                    <small class="text-muted">65% XP</small>
                  </div>

                  <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
                    <span class="shop-state-chip <%= active ? 'shop-state-chip--equipped' : owned ? 'shop-state-chip--owned' : 'shop-state-chip--available' %>">
                      <%= active ? t('purchases.new.cosmetics.status_active') : owned ? t('purchases.new.cosmetics.status_owned') : t('purchases.new.cosmetics.status_available') %>
                    </span>
                    <% if item.price_coins.present? %>
                      <span class="quest-meta"><%= t('purchases.new.prices.orbs', count: item.price_coins) %></span>
                    <% elsif item.price_free_credits.present? %>
                      <span class="quest-meta"><%= t('purchases.new.prices.fragments', count: item.price_free_credits) %></span>
                    <% elsif item.price_euros.present? %>
                      <span class="quest-meta"><%= t('purchases.new.prices.euros', count: item.price_euros) %></span>
                    <% end %>
                  </div>

                  <% if !cosmetics_activation_supported %>
                    <span class="badge text-bg-secondary"><%= t('purchases.new.cosmetics.activation_unavailable') %></span>
                  <% elsif active %>
                    <%= button_to "Desactiver", activate_cosmetic_path, method: :post, params: { shop_item_id: nil, cosmetic_type: "xp_theme" }, class: "btn btn-sm btn-outline-secondary" %>
                  <% elsif owned %>
                    <%= button_to "Activer", activate_cosmetic_path, method: :post, params: { shop_item_id: item.id, cosmetic_type: "xp_theme" }, class: "btn btn-sm btn-brand" %>
                  <% elsif item.price_coins.present? || item.price_free_credits.present? || item.price_euros.present? %>
                    <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                      <%= hidden_field_tag :shop_item_id, item.id %>
                      <%= submit_tag t('purchases.new.cosmetics.buy_button'), class: "btn btn-outline-quest" %>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>

            <!-- Cartes de Visite -->
            <h3 class="section-title mt-4"><%= t('purchases.new.cosmetics.profile_cards_heading') %></h3>
            <div class="shop-list shop-list--flat">
              <% @card_items.each do |item| %>
                <% rarity_key = item.rarity.to_s.presence || "common" %>
                <% owned = @owned_item_ids.include?(item.id) %>
                <% active = cosmetics_activation_supported && active_profile_card_id == item.id %>
                <div class="shop-row shop-row--flat">
                  <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                    <strong class="shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= item.name %></strong>
                    <span class="rarity-chip rarity-chip--<%= rarity_key %>"><%= item.rarity.to_s.capitalize %></span>
                  </div>
                  <p class="quest-meta mb-2"><%= @item_personalized_descriptions[item.id] %></p>

                  <!-- Aperçu de la carte -->
                  <div class="shop-cosmetic-preview shop-cosmetic-preview--<%= rarity_key %> mb-2">
                    <div class="preview-label"><%= t('purchases.new.cosmetics.preview_label') %></div>
                    <div class="profile-card-container <%= profile_card_classes(item) %>">
                      <div class="profile-card-header">
                        <%= current_user.pseudo %>
                      </div>
                      <div class="profile-card-text">
                        <%= t('purchases.new.cosmetics.card_preview_hint') %>
                      </div>
                    </div>
                  </div>

                  <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
                    <span class="shop-state-chip <%= active ? 'shop-state-chip--equipped' : owned ? 'shop-state-chip--owned' : 'shop-state-chip--available' %>">
                      <%= active ? t('purchases.new.cosmetics.status_active_f') : owned ? t('purchases.new.cosmetics.status_owned') : t('purchases.new.cosmetics.status_available') %>
                    </span>
                    <% if item.price_coins.present? %>
                      <span class="quest-meta"><%= t('purchases.new.prices.orbs', count: item.price_coins) %></span>
                    <% elsif item.price_free_credits.present? %>
                      <span class="quest-meta"><%= t('purchases.new.prices.fragments', count: item.price_free_credits) %></span>
                    <% elsif item.price_euros.present? %>
                      <span class="quest-meta"><%= t('purchases.new.prices.euros', count: item.price_euros) %></span>
                    <% end %>
                  </div>

                  <% if !cosmetics_activation_supported %>
                    <span class="badge text-bg-secondary"><%= t('purchases.new.cosmetics.activation_unavailable') %></span>
                  <% elsif active %>
                    <%= button_to "Desactiver", activate_cosmetic_path, method: :post, params: { shop_item_id: nil, cosmetic_type: "profile_card" }, class: "btn btn-sm btn-outline-secondary" %>
                  <% elsif owned %>
                    <%= button_to "Activer", activate_cosmetic_path, method: :post, params: { shop_item_id: item.id, cosmetic_type: "profile_card" }, class: "btn btn-sm btn-brand" %>
                  <% elsif item.price_coins.present? || item.price_free_credits.present? || item.price_euros.present? %>
                    <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                      <%= hidden_field_tag :shop_item_id, item.id %>
                      <%= submit_tag t('purchases.new.cosmetics.buy_button'), class: "btn btn-outline-quest" %>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% elsif @active_shop_tab == "rewards" %>
            <h2 class="section-title"><%= t('purchases.new.rewards.heading') %></h2>
            <p class="quest-meta mb-3"><%= t('purchases.new.rewards.instruction') %></p>
            <div class="shop-row shop-row--flat mb-3">
              <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
                <strong>❄️ <%= t('purchases.new.streak_freeze.heading') %></strong>
                <span class="shop-state-chip shop-state-chip--available"><%= t('purchases.new.streak_freeze.owned', count: current_user.streak_freeze_tokens) %></span>
              </div>
              <p class="quest-meta mb-2"><%= t('purchases.new.streak_freeze.hint', cost: PurchasesController::STREAK_FREEZE_COST_FRAGMENTS) %></p>
              <%= button_to t('purchases.new.streak_freeze.buy_button', cost: PurchasesController::STREAK_FREEZE_COST_FRAGMENTS), buy_streak_freeze_purchases_path, method: :post, class: "btn btn-sm btn-brand" %>
            </div>
            <% reward_items = Array(@free_reward_items) %>
            <% if reward_items.any? %>
              <div class="shop-list shop-list--flat">
                <% reward_items.each do |item| %>
                <% rarity_key = item.rarity.to_s.presence || "common" %>
                <% owned = @owned_item_ids.include?(item.id) %>
                <% fallback_orbes_price = (item.price_free_credits.to_i / 2.0).ceil %>
                <div class="shop-row shop-row--flat">
                  <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                    <strong class="shop-rarity-text shop-rarity-text--<%= rarity_key %>"><%= item.name %></strong>
                    <span class="rarity-chip rarity-chip--<%= rarity_key %>"><%= item.rarity.to_s.capitalize %></span>
                  </div>
                  <p class="quest-meta mb-2"><%= @item_personalized_descriptions[item.id] %></p>

                  <div class="shop-cosmetic-preview shop-cosmetic-preview--<%= rarity_key %> mb-2">
                    <div class="preview-label"><%= t('purchases.new.cosmetics.preview_label') %></div>
                    <% if item.item_type == "profile_frame" %>
                      <div class="profile-frame-container <%= frame_wrapper_classes(item) %>">
                        <%= current_user.pseudo %>
                      </div>
                    <% elsif item.item_type == "xp_theme" %>
                      <div class="xp-track <%= xp_theme_classes(item) %>">
                        <div class="xp-fill" style="width: 67%"></div>
                      </div>
                    <% elsif item.item_type == "profile_card" %>
                      <div class="profile-card-container <%= profile_card_classes(item) %>">
                        <div class="profile-card-header"><%= current_user.pseudo %></div>
                        <div class="profile-card-text"><%= t('purchases.new.rewards.edition', name: item.name) %></div>
                      </div>
                    <% elsif item.item_type == "title" %>
                      <span class="shop-state-chip shop-state-chip--available"><%= item.name %></span>
                    <% end %>
                  </div>

                  <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
                    <span class="shop-state-chip <%= owned ? 'shop-state-chip--owned' : 'shop-state-chip--available' %>">
                      <%= owned ? t('purchases.new.cosmetics.status_owned') : t('purchases.new.cosmetics.status_available') %>
                    </span>
                    <span class="quest-meta"><%= t('purchases.new.prices.fragments_or_orbs', fragments: item.price_free_credits, orbs: fallback_orbes_price) %></span>
                  </div>


                  <% if owned %>
                    <% if item.item_type == "title" %>
                      <%= button_to "Equiper", activate_title_path, method: :post, params: { shop_item_id: item.id }, class: "btn btn-sm btn-brand" %>
                    <% elsif %w[profile_frame xp_theme profile_card].include?(item.item_type) %>
                      <%= button_to "Activer", activate_cosmetic_path, method: :post, params: { shop_item_id: item.id, cosmetic_type: item.item_type }, class: "btn btn-sm btn-brand" %>
                    <% else %>
                      <span class="badge text-bg-success"><%= t('purchases.new.rewards.unlocked_badge') %></span>
                    <% end %>
                  <% else %>
                    <div class="d-grid gap-2">
                      <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                        <%= hidden_field_tag :shop_item_id, item.id %>
                        <%= hidden_field_tag :currency, "fragments" %>
                        <%= submit_tag t('purchases.new.rewards.unlock_with_fragments', count: item.price_free_credits),
                                       class: "btn btn-outline-quest",
                                       disabled: current_user.free_credits_balance < item.price_free_credits.to_i %>
                      <% end %>
                      <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid" do %>
                        <%= hidden_field_tag :shop_item_id, item.id %>
                        <%= hidden_field_tag :currency, "orbes" %>
                        <%= submit_tag t('purchases.new.rewards.unlock_with_orbs', count: fallback_orbes_price),
                                       class: "btn btn-outline-secondary",
                                       disabled: current_user.coins < fallback_orbes_price %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
                <% end %>
              </div>
            <% else %>
              <div class="alert alert-warning mb-0"><%= t('purchases.new.rewards.none') %></div>
            <% end %>
          <% end %>
        </section>
      </div>

      <div class="col-lg-4">
        <section class="hud-section h-100">
          <h2 class="section-title"><%= t('purchases.new.preview.heading') %></h2>
          <% preview_frame = @preview_profile_frame %>
          <% preview_theme = @preview_xp_theme %>
          <% preview_card = @preview_profile_card %>
          <% preview_title = @preview_title %>
          <div id="shop-preview-card" class="shop-preview-card profile-card-container <%= profile_card_classes(preview_card) %> mb-4">
            <div class="shop-impact-profile mb-3">
              <div class="d-flex align-items-center gap-3">
                <%= user_avatar_image(current_user, width: 74, height: 74, css_class: "rounded-circle shop-preview-avatar", alt: t('purchases.new.preview.avatar_alt', pseudo: current_user.pseudo)) %>
                <div class="shop-preview-meta">
                  <div id="shop-preview-frame" class="profile-frame-container <%= frame_wrapper_classes(preview_frame) %>">
                    <strong><%= current_user.pseudo %></strong>
                  </div>
                  <p class="quest-meta mb-1 mt-2">Niveau global <%= @total_level %></p>
                  <% if preview_title.present? %>
                    <p id="shop-preview-title" class="quest-meta mb-0 shop-preview-meta-row"><%= t('purchases.new.preview.title_label', name: preview_title.name) %></p>
                  <% else %>
                    <p id="shop-preview-title" class="quest-meta mb-0 shop-preview-meta-row"><%= t('purchases.new.preview.no_title') %></p>
                  <% end %>
                  <p id="shop-preview-frame-name" class="quest-meta mb-0 shop-preview-meta-row"><%= t('purchases.new.preview.frame_label', name: preview_frame&.name || t('purchases.new.preview.none')) %></p>
                  <p id="shop-preview-theme-name" class="quest-meta mb-0 shop-preview-meta-row"><%= t('purchases.new.preview.theme_label', name: preview_theme&.name || t('purchases.new.preview.standard')) %></p>
                </div>
              </div>
            </div>

            <div class="shop-impact-xp mb-3">
              <div class="d-flex align-items-center justify-content-between mb-1">
                <span class="preview-label"><%= t('purchases.new.preview.xp_bar_label') %></span>
                <span class="quest-meta">67%</span>
              </div>
              <div id="shop-preview-xp-track" class="xp-track shop-impact-xp-track <%= xp_theme_classes(preview_theme) %>">
                <div class="xp-fill" style="width: 67%"></div>
              </div>
            </div>

            <div class="shop-impact-card">
              <div class="preview-label mb-1"><%= t('purchases.new.preview.card_label') %></div>
              <p id="shop-preview-card-text" class="profile-card-text mb-0">
                <%= preview_card.present? ? t('purchases.new.preview.simulation', name: preview_card.name) : (profile_card_text(current_user).presence || t('purchases.new.preview.card_placeholder')) %>
              </p>
            </div>
          </div>

            <h2 class="section-title"><%= t('purchases.new.packs_heading') %></h2>
            <div class="shop-list shop-list--flat shop-list--boosts mb-4">
              <% @coins_prices.each do |option| %>
                <% value_per_euro = (option[:total_coins].to_f / option[:amount]).round(1) %>
                <div class="shop-row shop-row--flat pack-row">
                  <%= form_with url: purchases_path, method: :post, local: true, class: "d-grid gap-2" do %>
                    <%= hidden_field_tag :amount, option[:amount] %>
                    <%= hidden_field_tag :item_type, option[:label] %>
                    <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                      <strong><%= option[:label] %></strong>
                      <div class="d-flex align-items-center gap-2 flex-wrap">
                        <% if option[:bonus_coins].positive? %>
                          <span class="shop-state-chip shop-state-chip--equipped"><%= t('purchases.new.packs.bonus_badge', percentage: (option[:bonus_coins].to_f / option[:coins] * 100).round) %></span>
                        <% end %>
                        <% if option[:label] == @best_value_pack_label %>
                          <span class="shop-state-chip shop-state-chip--best"><%= t('purchases.new.packs.best_value_badge') %></span>
                        <% end %>
                      </div>
                    </div>

                    <div class="pack-total-line mb-1">
                      <span class="pack-total-main"><%= t('purchases.new.packs.orbs_received', count: option[:total_coins]) %></span>
                      <% if option[:bonus_coins].positive? %>
                        <span class="pack-total-detail"><%= t('purchases.new.packs.base_bonus', base: option[:coins], bonus: option[:bonus_coins]) %></span>
                      <% end %>
                    </div>

                    <p class="quest-meta mb-1"><%= option[:description] %></p>
                    <p class="quest-meta mb-1"><%= t('purchases.new.packs.rate', orbs: value_per_euro) %></p>
                    <%= submit_tag t('purchases.new.packs.buy_button', price: option[:amount]), class: "btn btn-brand" %>
                  <% end %>
                </div>
              <% end %>
            </div>

          <hr class="hud-divider">

          <h2 class="section-title"><%= t('purchases.new.challenge.heading') %></h2>
          <p class="quest-meta mb-2"><%= t('purchases.new.challenge.instruction', count: PurchasesController::SHOP_CHALLENGE_REWARD_FREE_CREDITS) %></p>
          <div class="shop-challenge-card mb-3">
            <% @shop_challenge.fetch(:steps, []).each do |step| %>
              <div class="shop-challenge-step">
                <span class="shop-state-chip <%= step[:completed] ? 'shop-state-chip--equipped' : 'shop-state-chip--available' %>">
                  <%= step[:completed] ? t('purchases.new.challenge.done') : t('purchases.new.challenge.todo') %>
                </span>
                <span><%= step[:label] %></span>
              </div>
            <% end %>
          </div>

          <% if @shop_challenge_claimed %>
            <span class="shop-state-chip shop-state-chip--owned"><%= t('purchases.new.challenge.already_claimed') %></span>
          <% elsif @shop_challenge[:completed_all] %>
            <%= button_to t('purchases.new.challenge.claim_button'), claim_weekly_challenge_purchases_path, method: :post, class: "btn btn-brand" %>
          <% else %>
            <span class="shop-state-chip shop-state-chip--available"><%= t('purchases.new.challenge.progress', done: @shop_challenge.fetch(:completed_count, 0), total: @shop_challenge.fetch(:total_count, 0)) %></span>
          <% end %>
        </section>
      </div>
    </div>
  </div>
</div>

<div class="mt-4">
  <%= link_to t('common.back_to_dashboard'), root_path, class: "btn btn-outline-secondary" %>
</div>
