<% content_for :title, "Leveling | Progression gamifiee" %>
<% content_for :meta_description, "Leveling transforme ta progression personnelle en jeu: quetes, ligues hebdo, streaks et defis entre amis." %>

<section class="welcome-hero surface-card surface-card--shell mb-4">
  <div class="card-body">
    <p class="welcome-kicker mb-2">Progression gamifiee</p>
    <h1 class="page-title mb-3">Transforme ta progression en jeu competitif</h1>
    <p class="page-subtitle mb-4">
      Construis ta discipline avec des quetes courtes, grimpe dans les ligues hebdomadaires,
      et garde ton elan avec des rewards quotidiennes.
    </p>

    <div class="welcome-cta d-flex gap-2 flex-wrap">
      <%= link_to "Commencer maintenant", new_user_registration_path(@signup_params), class: "btn btn-brand btn-arcade" %>
      <%= link_to "J'ai deja un compte", new_user_session_path(@signup_params), class: "btn btn-outline-quest btn-arcade" %>
    </div>

    <% if @invite_ref.present? %>
      <div class="alert alert-warning mt-4 mb-0">
        Invitation detectee: code <strong><%= @invite_ref %></strong>. Cree ton compte pour rejoindre la meme dynamique de progression.
      </div>
    <% end %>
  </div>
</section>

<section class="surface-card mb-4">
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-4">
        <div class="welcome-stat">
          <strong><%= @players_count %>+</strong>
          <span>joueurs motives</span>
        </div>
      </div>
      <div class="col-md-4">
        <div class="welcome-stat">
          <strong><%= @quests_count %>+</strong>
          <span>quetes disponibles</span>
        </div>
      </div>
      <div class="col-md-4">
        <div class="welcome-stat">
          <strong><%= @categories_count %></strong>
          <span>axes de progression</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="surface-card">
  <div class="card-body">
    <h2 class="section-title mb-3">Pourquoi les joueurs restent</h2>
    <div class="row g-3">
      <div class="col-md-4">
        <div class="quest-row quest-row--flat h-100">
          <strong>1. Action immediate</strong>
          <p class="quest-meta mb-0">Tu choisis une quete, tu valides, tu progresses en quelques minutes.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="quest-row quest-row--flat h-100">
          <strong>2. Competition saine</strong>
          <p class="quest-meta mb-0">Tu compares ta semaine a ta cohorte de ligue, avec projections claires.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="quest-row quest-row--flat h-100">
          <strong>3. Regularite recompensee</strong>
          <p class="quest-meta mb-0">Streaks, coffre quotidien et progression visible pour garder le rythme.</p>
        </div>
      </div>
    </div>
  </div>
</section>
