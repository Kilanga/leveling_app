<% content_for :title, "Leveling | #{t('welcome.index.page_title')}" %>
<% content_for :meta_description, t('welcome.index.page_subtitle') %>

<section class="welcome-hero surface-card surface-card--shell mb-4">
  <div class="card-body">
    <p class="welcome-kicker mb-2"><%= t('welcome.index.page_title') %></p>
    <h1 class="page-title mb-3"><%= t('welcome.index.main_heading') %></h1>
    <p class="page-subtitle mb-4">
      <%= t('welcome.index.sub_heading') %>
    </p>

    <div class="welcome-cta d-flex gap-2 flex-wrap">
      <%= link_to t('welcome.index.start_button'), new_user_registration_path(@signup_params), class: "btn btn-brand btn-arcade" %>
      <%= link_to t('welcome.index.existing_account_button'), new_user_session_path(@signup_params), class: "btn btn-outline-quest btn-arcade" %>
    </div>

    <% if @invite_ref.present? %>
      <div class="alert alert-warning mt-4 mb-0">
        <%= t('welcome.index.detected_referral', code: @invite_ref) %>
      </div>
    <% end %>
  </div>
</section>

<section class="surface-card mb-4">
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-4">
        <div class="welcome-stat">
          <strong><%= @players_count %>+</strong>
          <span><%= t('welcome.index.stats.motivated_players') %></span>
        </div>
      </div>
      <div class="col-md-4">
        <div class="welcome-stat">
          <strong><%= @quests_count %>+</strong>
          <span><%= t('welcome.index.stats.available_quests') %></span>
        </div>
      </div>
      <div class="col-md-4">
        <div class="welcome-stat">
          <strong><%= @categories_count %></strong>
          <span><%= t('welcome.index.stats.progression_axes') %></span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="surface-card">
  <div class="card-body">
    <h2 class="section-title mb-3"><%= t('welcome.index.benefits_heading') %></h2>
    <div class="row g-3">
      <div class="col-md-4">
        <div class="quest-row quest-row--flat h-100">
          <strong><%= t('welcome.index.benefit_1_title') %></strong>
          <p class="quest-meta mb-0"><%= t('welcome.index.benefit_1_desc') %></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="quest-row quest-row--flat h-100">
          <strong><%= t('welcome.index.benefit_2_title') %></strong>
          <p class="quest-meta mb-0"><%= t('welcome.index.benefit_2_desc') %></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="quest-row quest-row--flat h-100">
          <strong><%= t('welcome.index.benefit_3_title') %></strong>
          <p class="quest-meta mb-0"><%= t('welcome.index.benefit_3_desc') %></p>
        </div>
      </div>
    </div>
  </div>
</section>
