<% dashboard_rank = HunterRank.for_user(current_user) %>
<% hero_ring_c = 327 %>
<% hero_ring_off = (hero_ring_c * (1 - [[dashboard_rank[:progress].to_f, 0].max, 1].min)).round %>
<% dash_card = current_user.active_profile_card %>
<% dash_card_theme = dash_card.present? ? profile_card_classes(dash_card).to_s.gsub("profile-card-", "player-home-theme--") : "player-home-theme--none" %>
<% dash_card_text = dash_card.present? ? profile_card_text(current_user) : nil %>
<section class="game-hero player-home-shell <%= dash_card_theme %> mb-4">
  <div class="game-hero__main">
    <div class="game-hero__identity">
      <%= user_avatar_image(current_user, width: 76, height: 76, css_class: "game-hero__avatar", alt: current_user.pseudo) %>
      <div>
        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
          <span class="profile-frame-container game-hero__name <%= frame_wrapper_classes(current_user.active_profile_frame) %>"><%= current_user.pseudo %></span>
          <%= hunter_rank_badge(dashboard_rank) %>
          <% if current_user.boost_active? %>
            <span class="badge text-bg-warning"><%= t('dashboard.xp_boost_active', date: l(current_user.boost_expires_at, format: :short)) %></span>
          <% end %>
          <% if current_user.active_title.present? %>
            <span class="badge bg-<%= current_user.title_rarity_class %>"><%= current_user.active_title.name %></span>
          <% end %>
        </div>
        <p class="page-subtitle mb-0"><%= dash_card_text.presence || t('dashboard.subtitle') %></p>
      </div>
    </div>

    <div class="game-chips">
      <span class="game-chip">🔥 <%= t('dashboard.weekly_streak_label', count: @weekly_streak_count) %></span>
      <span class="game-chip game-chip--accent"><%= t('dashboard.daily_objective.title') %> · <%= @completed_today_count %> / <%= @daily_target %></span>
      <%= link_to t('dashboard.view_league'), leaderboard_index_path, class: "game-chip", style: "text-decoration:none;" %>
    </div>

    <div class="game-hero__progress">
      <div class="xp-track <%= xp_theme_classes(current_user.active_xp_theme) %>"><div class="xp-fill" style="width: <%= @daily_progress_percent %>%"></div></div>
      <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mt-3">
        <p class="quest-meta mb-0"><%= t('dashboard.daily_objective.chest_reward', amount: @daily_chest_reward_free_credits) %></p>
        <% if @daily_chest_claimed_today %>
          <span class="badge text-bg-success"><%= t('dashboard.daily_objective.chest_opened') %></span>
        <% else %>
          <%= button_to t('dashboard.daily_objective.open_chest_button'), claim_daily_chest_path, method: :post, class: "btn btn-sm btn-brand", disabled: @completed_today_count < @daily_target %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="game-hero__ring">
    <svg width="150" height="150" viewBox="0 0 150 150" style="transform: rotate(-90deg);">
      <circle cx="75" cy="75" r="52" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="12"></circle>
      <circle cx="75" cy="75" r="52" fill="none" stroke="var(--game-accent)" stroke-width="12" stroke-linecap="round" stroke-dasharray="<%= hero_ring_c %>" stroke-dashoffset="<%= hero_ring_off %>" style="filter: drop-shadow(0 0 8px rgba(79,168,255,0.6));"></circle>
    </svg>
    <div class="game-hero__ring-label">
      <div class="game-hero__ring-level"><%= @total_level %></div>
      <div class="quest-meta mt-1"><%= dashboard_rank[:letter] %><% if dashboard_rank[:next_threshold] %> · <%= dashboard_rank[:level] %>/<%= dashboard_rank[:next_threshold] %><% end %></div>
    </div>
  </div>
</section>

<div class="hud-alerts mb-4">
<% if ENV["VAPID_PUBLIC_KEY"].present? %>
  <div class="hud-alert push-prompt" role="complementary">
    <div class="card-body d-flex justify-content-between align-items-center gap-3 flex-wrap">
      <div>
        <strong><%= t('dashboard.push_prompt.heading') %></strong>
        <p class="quest-meta mb-0"><%= t('dashboard.push_prompt.hint') %></p>
      </div>
      <button id="enable-push-btn" class="btn btn-sm btn-brand"
              data-vapid-key="<%= ENV["VAPID_PUBLIC_KEY"] %>"
              data-csrf="<%= form_authenticity_token %>">
        <%= t('dashboard.push_prompt.cta') %>
      </button>
    </div>
  </div>
<% end %>

<% if @show_quickstart_guide %>
  <div class="hud-alert" role="status" aria-live="polite">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-2">
        <div>
          <h2 class="section-title mb-1"><%= t('dashboard.quickstart.heading') %></h2>
          <p class="quest-meta mb-0"><%= t('dashboard.quickstart.progress_hint', done: @quickstart_guide[:completed_count], total: @quickstart_guide[:total_count]) %></p>
        </div>
        <span class="shop-state-chip <%= @quickstart_guide[:completed_count] == @quickstart_guide[:total_count] ? 'shop-state-chip--equipped' : 'shop-state-chip--available' %>">
          <%= @quickstart_guide[:completed_count] %> / <%= @quickstart_guide[:total_count] %>
        </span>
      </div>

      <div class="quest-list quest-list--flat mb-0">
        <% @quickstart_guide[:steps].each do |step| %>
          <div class="quest-row quest-row--flat d-flex justify-content-between align-items-center gap-3 flex-wrap">
            <div>
              <strong><%= step[:label] %></strong>
            </div>
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <% if step[:completed] %>
                <span class="badge text-bg-success"><%= t('dashboard.quickstart.done_badge') %></span>
              <% else %>
                <%= link_to step[:cta_label], step[:cta_path], class: "btn btn-sm btn-outline-quest" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<% if @daily_login_claim[:claimed] %>
  <div class="hud-alert" role="status" aria-live="polite">
    <div class="card-body d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div>
        <strong><%= t('dashboard.daily_bonus_claimed', amount: @daily_login_claim[:reward]) %></strong>
        <p class="quest-meta mb-0"><%= t('dashboard.streak_days', days: @daily_login_claim[:streak]) %></p>
      </div>
      <span class="shop-state-chip shop-state-chip--equipped"><%= t('dashboard.daily_login_chip') %></span>
    </div>
  </div>
<% end %>

<% if flash[:streak_up_quest_title].present? && flash[:streak_up_value].present? %>
  <div class="hud-alert streak-up-banner" role="status" aria-live="polite">
    <div class="card-body d-flex justify-content-between align-items-center gap-2 flex-wrap">
      <strong><%= t('dashboard.streak_up_label', title: flash[:streak_up_quest_title]) %></strong>
      <span class="streak-up-banner__value">x<%= flash[:streak_up_value] %></span>
    </div>
  </div>
<% end %>

<% if @shop_upgrade_prompt.present? %>
  <div class="hud-alert" role="complementary" aria-label="Suggestion boutique">
    <div class="card-body d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div>
        <h2 class="section-title mb-1"><%= t('dashboard.boost_prompt.heading') %></h2>
        <p class="quest-meta mb-0"><%= t('dashboard.boost_prompt.hint', count: @shop_upgrade_prompt[:quest_completions_7d]) %></p>
      </div>
      <%= link_to t('dashboard.boost_prompt.cta'), @shop_upgrade_prompt[:cta_path], class: "btn btn-sm btn-brand" %>
    </div>
  </div>
<% end %>
</div>

<div class="surface-card mb-4">
  <div class="card-body">
        <h2 class="section-title mb-3"><%= t('dashboard.factions.title') %></h2>
        <% if @next_faction_reset_at.present? %>
          <p class="quest-meta mb-2"><%= t('dashboard.factions.reset_in', time: @faction_reset_countdown) %></p>
        <% end %>
        <% if current_user.faction.present? %>
          <p class="quest-meta mb-2"><%= t('dashboard.factions.current_faction', name: current_user.faction.name) %></p>
          <% boss = FactionBoss.progress_for(current_user.faction) %>
          <div class="quest-row quest-row--flat mb-3">
            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-1">
              <strong><%= t('dashboard.faction_boss.heading') %></strong>
              <% if boss[:defeated] %>
                <span class="shop-state-chip shop-state-chip--equipped"><%= t('dashboard.faction_boss.defeated') %></span>
              <% else %>
                <span class="shop-state-chip shop-state-chip--available"><%= boss[:points] %>/<%= boss[:target] %></span>
              <% end %>
            </div>
            <p class="quest-meta mb-2"><%= t('dashboard.faction_boss.hint', target: boss[:target], reward: FactionBoss::REWARD_FRAGMENTS) %></p>
            <div class="xp-track">
              <div class="xp-fill" style="width: <%= (boss[:ratio] * 100).round %>%"></div>
            </div>
          </div>
          <% unless @can_change_faction %>
            <p class="quest-meta mb-2"><%= t('dashboard.factions.change_locked') %></p>
          <% end %>
        <% else %>
          <p class="quest-meta mb-2"><%= t('dashboard.factions.choose_faction') %></p>
        <% end %>

        <% if @previous_winning_faction.present? && @previous_winning_faction.try(:previous_points).to_i > 0 %>
          <div class="quest-row quest-row--flat mb-3">
            <strong><%= t('dashboard.factions.previous_winner', name: @previous_winning_faction.name) %></strong>
          </div>
          <details class="quest-row quest-row--flat mb-3">
            <summary class="d-flex justify-content-between align-items-center gap-2 flex-wrap" style="cursor: pointer;">
              <span><%= t('dashboard.factions.view_participants') %></span>
              <span class="badge text-bg-dark"><%= t('dashboard.factions.view_participants') %></span>
            </summary>
            <div class="mt-2">
              <% if @previous_winning_participants.any? %>
                <div class="quest-list quest-list--flat">
                  <% @previous_winning_participants.each do |entry| %>
                    <div class="quest-row quest-row--flat d-flex justify-content-between align-items-center gap-2 flex-wrap">
                      <span><strong><%= entry.user&.pseudo || t('dashboard.unknown_player') %></strong></span>
                      <span class="quest-meta"><%= entry.points %> pts</span>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="quest-meta mb-0"><%= t('dashboard.factions.no_participants') %></p>
              <% end %>
            </div>
          </details>
        <% end %>

        <% if @leading_faction.present? %>
          <div class="quest-row quest-row--flat mb-3">
            <strong><%= t('dashboard.factions.dominant_faction', name: @leading_faction.name) %></strong>
            <p class="quest-meta mb-0"><%= t('dashboard.factions.influence_points', count: @leading_faction.try(:today_points).to_i) %></p>
          </div>
        <% end %>

        <div class="quest-list quest-list--flat">
          <% @faction_scores_today.each do |faction| %>
            <div class="quest-row quest-row--flat d-flex justify-content-between align-items-center gap-3 flex-wrap">
              <div>
                <strong><%= faction.name %></strong>
                <p class="quest-meta mb-0"><%= t('dashboard.factions.influence_points', count: faction.try(:today_points).to_i) %></p>
              </div>
              <% if current_user.faction_id == faction.id %>
                <span class="badge text-bg-success"><%= t('dashboard.factions.equipped_badge') %></span>
              <% elsif current_user.faction.present? && !@can_change_faction %>
                <button type="button" class="btn btn-sm btn-outline-secondary" disabled><%= t('dashboard.factions.locked_badge') %></button>
              <% else %>
                <%= button_to t('dashboard.factions.join_button'), join_faction_path(faction), method: :post, class: "btn btn-sm btn-outline-quest", form: { data: { turbo: false } } %>
              <% end %>
            </div>
          <% end %>
        </div>
  </div>
</div>

<div class="surface-card game-panel--feature mb-4" id="system-quests">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
      <div>
        <h2 class="section-title mb-1"><%= t('dashboard.system_quests.title') %></h2>
        <p class="quest-meta mb-0"><%= t('dashboard.system_quests.subtitle') %></p>
      </div>
      <span class="shop-state-chip <%= @system_perfect_day ? 'shop-state-chip--equipped' : 'shop-state-chip--available' %>">
        <%= @system_assignments.count(&:completed?) %> / <%= @system_assignments.size %>
      </span>
    </div>

    <% if @weekly_progression_frozen %>
      <div class="alert alert-warning" role="alert">
        <%= t('dashboard.system_quests.frozen_warning') %>
      </div>
    <% end %>

    <% if @system_assignments.any? %>
      <div class="quest-list quest-list--flat mb-3">
        <% @system_assignments.each do |assignment| %>
          <div class="quest-row quest-row--flat">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
              <div>
                <span class="hunter-rank-badge hunter-rank-badge--<%= assignment.quest.difficulty.downcase %>" title="<%= t('dashboard.system_quests.difficulty_label', letter: assignment.quest.difficulty) %>"><%= assignment.quest.difficulty %></span>
                <strong><%= assignment.quest.title %></strong>
                <p class="quest-meta mb-0"><%= assignment.quest.category.name %> - <%= assignment.quest.xp %> XP</p>
              </div>
              <% if assignment.completed? %>
                <span class="badge text-bg-success"><%= t('dashboard.completed_badge') %></span>
              <% else %>
                <%= button_to t('dashboard.active_quests.validate_button'), complete_system_quest_path(assignment), method: :post, class: "btn btn-sm btn-brand" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <% if @system_perfect_day %>
        <div class="alert alert-success mb-0" role="status">
          <%= t('dashboard.system_quests.perfect_day_done') %>
        </div>
      <% else %>
        <p class="quest-meta mb-0"><%= t('dashboard.system_quests.perfect_day_hint', fragments: @system_perfect_day_fragments) %></p>
      <% end %>
    <% else %>
      <div class="alert alert-warning mb-0"><%= t('dashboard.system_quests.empty') %></div>
    <% end %>
  </div>
</div>

<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <div class="row g-4">
      <div class="col-lg-6">
        <section class="hud-section h-100">
          <h2 class="section-title"><%= t('dashboard.active_quests.title') %></h2>
          <div class="quest-list quest-list--flat mb-3">
            <% active_quests = @user_quests.where(completed: false, active: true) %>
            <% if active_quests.any? %>
              <% active_quests.each do |user_quest| %>
                <div class="quest-row quest-row--flat">
                  <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                      <strong><%= user_quest.quest.title %></strong>
                      <p class="quest-meta mb-1"><%= user_quest.quest.category.name %> - <%= user_quest.quest.xp %> XP</p>
                      <p class="quest-meta mb-0"><%= t('dashboard.completed_times', count: user_quest.completed_count) %></p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap quest-actions">
                      <%= form_with url: user_quest_path(user_quest), method: :patch, local: true do %>
                        <%= hidden_field_tag :action_type, "complete" %>
                        <%= submit_tag t('dashboard.active_quests.validate_button'), class: "btn btn-sm btn-brand" %>
                      <% end %>

                      <%= form_with url: user_quest_path(user_quest), method: :patch, local: true do %>
                        <%= hidden_field_tag :action_type, "unfollow" %>
                        <%= submit_tag t('dashboard.active_quests.stop_button'), class: "btn btn-sm btn-outline-danger" %>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div class="alert alert-warning mb-0"><%= t('dashboard.no_active_quest') %></div>
            <% end %>
          </div>
        </section>
      </div>

      <div class="col-lg-6">
        <section class="hud-section h-100">
          <h2 class="section-title"><%= t('dashboard.weekly_quests.title') %></h2>
          <% if @weekly_quests.any? %>
            <div class="quest-list quest-list--flat">
              <% @weekly_quests.each do |user_weekly_quest| %>
                <div class="quest-row quest-row--flat d-flex justify-content-between align-items-start gap-3 flex-wrap">
                  <div>
                    <strong><%= user_weekly_quest.weekly_quest.title %></strong>
                    <p class="quest-meta mb-1"><%= user_weekly_quest.weekly_quest.description %></p>
                    <p class="quest-meta mb-0"><%= t('dashboard.reward_label', count: user_weekly_quest.weekly_quest.xp_reward) %></p>
                  </div>
                  <% unless user_weekly_quest.completed? %>
                    <%= button_to t('dashboard.active_quests.validate_button'), user_weekly_quest_path(user_weekly_quest), method: :patch, params: { action_type: "complete" }, class: "btn btn-sm btn-brand" %>
                  <% else %>
                    <span class="badge text-bg-success"><%= t('dashboard.completed_badge') %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="alert alert-warning mb-0"><%= t('dashboard.weekly_quests_soon') %></div>
          <% end %>
        </section>
      </div>
    </div>

    <hr class="hud-divider">

    <section class="hud-section mb-4">
      <h2 class="section-title mb-3"><%= t('dashboard.progression_heading') %></h2>
      <div class="game-rings">
        <% ring_c = 226 %>
        <% @stats.each do |stat| %>
          <% xp_needed = xp_needed_for_next_level(stat.level) %>
          <% pct = [[stat.xp.to_f / [xp_needed, 1].max, 0].max, 1.0].min %>
          <% ring_off = (ring_c * (1 - pct)).round %>
          <div class="game-ring">
            <div class="game-ring__wrap">
              <svg width="84" height="84" viewBox="0 0 84 84" style="transform: rotate(-90deg);">
                <circle cx="42" cy="42" r="36" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="8"></circle>
                <circle cx="42" cy="42" r="36" fill="none" stroke="var(--game-accent)" stroke-width="8" stroke-linecap="round" stroke-dasharray="<%= ring_c %>" stroke-dashoffset="<%= ring_off %>"></circle>
              </svg>
              <div class="game-ring__label"><%= stat.level %></div>
            </div>
            <div>
              <div style="font-weight:700;color:#f4fbf7;"><%= stat.category.name %></div>
              <div class="quest-meta"><%= stat.xp %> / <%= xp_needed %> XP</div>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <section class="hud-section">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <span class="badge text-bg-dark"><%= t('dashboard.global_level_label', level: @total_level) %></span>
      </div>

      <% if @stats_data.any? %>
        <div class="stats-chart-wrap">
          <canvas
            id="statsChart"
            data-stats='<%= @stats_data.to_json %>'
            data-total-level="<%= @total_level %>">
          </canvas>
        </div>
      <% else %>
        <div class="alert alert-warning mb-0">
          Aucune donnee de progression disponible pour le moment.
        </div>
      <% end %>
    </section>
  </div>
</div>

<div class="surface-card mb-4">
  <div class="card-body">
    <h2 class="section-title mb-3"><%= t('dashboard.recent_activity.title') %></h2>
    <% if @friends_activity.any? %>
      <div class="quest-list quest-list--flat">
        <% @friends_activity.each do |event| %>
          <% metadata = event.metadata %>
          <div class="quest-row quest-row--flat d-flex justify-content-between align-items-center gap-3 flex-wrap">
            <div>
              <strong><%= event.user&.pseudo || "Un ami" %></strong>
              <p class="quest-meta mb-0">
                <% case event.event_name %>
                <% when "quest_completed" %>
                  <%= t('dashboard.recent_activity.completed_quest', xp: metadata["xp"].to_i) %>
                <% when "weekly_quest_completed" %>
                  <%= t('dashboard.recent_activity.completed_weekly_quest') %>
                <% when "daily_chest_claimed" %>
                  <%= t('dashboard.recent_activity.opened_chest', amount: metadata["reward_free_credits"].to_i) %>
                <% when "friend_request_accepted" %>
                  <%= t('dashboard.recent_activity.friend_accepted') %>
                <% else %>
                  vient de progresser.
                <% end %>
              </p>
            </div>
            <span class="muted-label"><%= l(event.created_at, format: :short) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-warning mb-0"><%= t('dashboard.recent_activity.no_activity') %></div>
    <% end %>
  </div>
</div>
