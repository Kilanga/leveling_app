<h1 class="page-title">
  Bienvenue, <%= current_user.pseudo %>
</h1>
<p class="page-subtitle">
  Votre quartier general de progression.
  <% if current_user.boost_active? %>
    <span class="badge text-bg-warning ms-2">Boost XP actif jusqu'a <%= l(current_user.boost_expires_at, format: :short) %></span>
  <% end %>
</p>

<% if @daily_login_claim[:claimed] %>
  <div class="surface-card mb-4" role="status" aria-live="polite">
    <div class="card-body d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div>
        <strong>Bonus connexion reclame: +<%= @daily_login_claim[:reward] %> coins</strong>
        <p class="quest-meta mb-0">Serie actuelle: <%= @daily_login_claim[:streak] %> jour(s).</p>
      </div>
      <span class="shop-state-chip shop-state-chip--equipped">Connexion du jour</span>
    </div>
  </div>
<% end %>

<div class="surface-card mb-4">
  <div class="card-body d-flex justify-content-between align-items-start gap-3 flex-wrap">
    <div>
      <strong>Streak hebdo: <%= @weekly_streak_count %> semaine(s)</strong>
      <p class="quest-meta mb-0">
        <% if @weekly_streak_last_completed_on.present? %>
          Derniere validation: <%= l(@weekly_streak_last_completed_on, format: :short) %>
        <% else %>
          Aucune validation cette semaine.
        <% end %>
      </p>
    </div>
    <%= link_to "Voir la ligue dans Classement", leaderboard_index_path, class: "btn btn-sm btn-outline-quest" %>
  </div>
</div>

<% if flash[:streak_up_quest_title].present? && flash[:streak_up_value].present? %>
  <div class="surface-card streak-up-banner mb-4" role="status" aria-live="polite">
    <div class="card-body d-flex justify-content-between align-items-center gap-2 flex-wrap">
      <strong>Streak up: <%= flash[:streak_up_quest_title] %></strong>
      <span class="streak-up-banner__value">x<%= flash[:streak_up_value] %></span>
    </div>
  </div>
<% end %>

<div class="surface-card daily-objective-card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div>
        <h2 class="section-title mb-1">Objectif du jour</h2>
        <p class="quest-meta mb-0">Valider <%= @daily_target %> quetes pour maintenir ton rythme.</p>
      </div>
      <span class="shop-state-chip <%= @completed_today_count >= @daily_target ? 'shop-state-chip--equipped' : 'shop-state-chip--available' %>">
        <%= @completed_today_count %> / <%= @daily_target %>
      </span>
    </div>
    <div class="xp-track mt-3">
      <div class="xp-fill" style="width: <%= @daily_progress_percent %>%"></div>
    </div>
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mt-3">
      <p class="quest-meta mb-0">Coffre quotidien: +<%= @daily_chest_reward_coins %> coins.</p>
      <% if @daily_chest_claimed_today %>
        <span class="badge text-bg-success">Coffre deja ouvert</span>
      <% else %>
        <%= button_to "Ouvrir le coffre", claim_daily_chest_path, method: :post, class: "btn btn-sm btn-brand", disabled: @completed_today_count < @daily_target %>
      <% end %>
    </div>
  </div>
</div>

<div class="surface-card mb-4">
  <div class="card-body">
    <h2 class="section-title mb-3">Activite recente des amis</h2>
    <% if @friends_activity.any? %>
      <div class="quest-list quest-list--flat">
        <% @friends_activity.each do |event| %>
          <% metadata = event.metadata %>
          <div class="quest-row quest-row--flat d-flex justify-content-between align-items-center gap-3 flex-wrap">
            <div>
              <strong><%= event.user&.pseudo || "Un ami" %></strong>
              <p class="quest-meta mb-0">
                <% case event.event_name %>
                <% when "quest_completed" %>
                  a complete une quete (+<%= metadata["xp"].to_i %> XP)
                <% when "weekly_quest_completed" %>
                  a valide sa quete hebdomadaire.
                <% when "daily_chest_claimed" %>
                  a ouvert le coffre quotidien (+<%= metadata["reward"].to_i %> coins)
                <% when "friend_request_accepted" %>
                  vient d'accepter une demande d'ami.
                <% else %>
                  vient de progresser.
                <% end %>
              </p>
            </div>
            <span class="muted-label"><%= l(event.created_at, format: :short) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-warning mb-0">Aucune activite amie recente. Ajoute des amis pour remplir ce feed.</div>
    <% end %>
  </div>
</div>

<div class="surface-card surface-card--shell mb-4">
  <div class="card-body">
    <div class="row g-4">
      <div class="col-lg-6">
        <section class="hud-section h-100">
          <h2 class="section-title">Quetes en cours</h2>
          <div class="quest-list quest-list--flat mb-3">
            <% active_quests = @user_quests.where(completed: false, active: true) %>
            <% if active_quests.any? %>
              <% active_quests.each do |user_quest| %>
                <div class="quest-row quest-row--flat">
                  <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                      <strong><%= user_quest.quest.title %></strong>
                      <p class="quest-meta mb-1"><%= user_quest.quest.category.name %> - <%= user_quest.quest.xp %> XP</p>
                      <p class="quest-meta mb-0">Completee <%= user_quest.completed_count %> fois</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap quest-actions">
                      <%= form_with url: user_quest_path(user_quest), method: :patch, local: true do %>
                        <%= hidden_field_tag :action_type, "complete" %>
                        <%= submit_tag "Valider", class: "btn btn-sm btn-brand" %>
                      <% end %>

                      <%= form_with url: user_quest_path(user_quest), method: :patch, local: true do %>
                        <%= hidden_field_tag :action_type, "unfollow" %>
                        <%= submit_tag "Arreter", class: "btn btn-sm btn-outline-danger" %>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div class="alert alert-warning mb-0">Aucune quete active. Lance ta prochaine mission.</div>
            <% end %>
          </div>
        </section>
      </div>

      <div class="col-lg-6">
        <section class="hud-section h-100">
          <h2 class="section-title">Quetes hebdomadaires</h2>
          <% if @weekly_quests.any? %>
            <div class="quest-list quest-list--flat">
              <% @weekly_quests.each do |user_weekly_quest| %>
                <div class="quest-row quest-row--flat d-flex justify-content-between align-items-start gap-3 flex-wrap">
                  <div>
                    <strong><%= user_weekly_quest.weekly_quest.title %></strong>
                    <p class="quest-meta mb-1"><%= user_weekly_quest.weekly_quest.description %></p>
                    <p class="quest-meta mb-0">Recompense: <%= user_weekly_quest.weekly_quest.xp_reward %> XP</p>
                  </div>
                  <% unless user_weekly_quest.completed? %>
                    <%= button_to "Valider", user_weekly_quest_path(user_weekly_quest), method: :patch, params: { action_type: "complete" }, class: "btn btn-sm btn-brand" %>
                  <% else %>
                    <span class="badge text-bg-success">Completee</span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="alert alert-warning mb-0">Nouvelles quetes hebdomadaires bientot.</div>
          <% end %>
        </section>
      </div>
    </div>

    <hr class="hud-divider">

    <div class="d-flex gap-2 flex-wrap mb-4">
      <%= link_to "Voir toutes les quetes", quests_path, class: "btn btn-brand btn-arcade" %>
      <%= link_to "Boutique", new_purchase_path, class: "btn btn-outline-quest btn-arcade" %>
      <%= link_to "Signaler un bug", "https://github.com/Kilanga/leveling_app/issues/new", class: "btn btn-outline-secondary btn-arcade", target: "_blank", rel: "noopener" %>
    </div>

    <section class="hud-section mb-4">
      <h2 class="section-title mb-3">Progression des categories</h2>
      <% @stats.each do |stat| %>
        <% xp_needed = xp_needed_for_next_level(stat.level) %>
        <% percent = (stat.xp.to_f / [xp_needed, 1].max * 100).round %>
        <div class="mb-3">
          <div class="d-flex justify-content-between flex-wrap gap-2 mb-1">
            <strong><%= stat.category.name %> - Niveau <%= stat.level %></strong>
            <span class="muted-label"><%= stat.xp %> / <%= xp_needed %> XP</span>
          </div>
          <div class="xp-track <%= xp_theme_classes(current_user.active_xp_theme) %>">
            <div class="xp-fill" style="width: <%= percent %>%"></div>
          </div>
        </div>
      <% end %>
    </section>

    <section class="hud-section">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <span class="badge text-bg-dark">Niveau global: <%= @total_level %></span>
      </div>

      <% if @stats_data.any? %>
        <div class="stats-chart-wrap">
          <canvas
            id="statsChart"
            data-stats='<%= @stats_data.to_json %>'
            data-total-level="<%= @total_level %>">
          </canvas>
        </div>
      <% else %>
        <div class="alert alert-warning mb-0">
          Aucune donnee de progression disponible pour le moment.
        </div>
      <% end %>
    </section>
  </div>
</div>
