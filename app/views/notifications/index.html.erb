<h1 class="page-title">Notifications</h1>

<div class="d-flex justify-content-between align-items-center mb-3 gap-2 flex-wrap">
  <p class="page-subtitle mb-0">Retrouve les rappels utiles, defis et activites sociales.</p>
  <%= button_to "Tout marquer lu", mark_all_read_notifications_path, method: :patch, class: "btn btn-outline-secondary" %>
</div>

<div class="surface-card surface-card--shell">
  <div class="card-body">
    <% if @notifications.any? %>
      <div class="shop-list shop-list--flat">
        <% @notifications.each do |notification| %>
          <div class="shop-row shop-row--flat d-flex justify-content-between align-items-start gap-3 flex-wrap">
            <div>
              <strong><%= notification.title %></strong>
              <p class="quest-meta mb-1"><%= notification.body %></p>
              <p class="quest-meta mb-0"><%= l(notification.created_at, format: :short) %></p>
            </div>
            <div class="d-flex gap-2">
              <% if notification.read_at.present? %>
                <span class="shop-state-chip shop-state-chip--owned">Lue</span>
              <% else %>
                <%= button_to "Ouvrir", notification_path(notification), method: :patch, class: "btn btn-sm btn-brand" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-warning mb-0">Aucune notification pour le moment.</div>
    <% end %>
  </div>
</div>
